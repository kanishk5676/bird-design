def load_dat_file(filepath: str) -> tuple[np.ndarray, dict]:
    """
    Load a .dat airfoil file and extract embedded metadata.

    Returns
    -------
    coords   : np.ndarray (N, 2)   chord-normalised x, y
    meta     : dict                 key→value pairs parsed from # comments
    """
    meta = {}
    coord_lines = []

    with open(filepath, 'r', encoding='utf-8', errors='replace') as f:
        for line in f:
            stripped = line.strip()
            if stripped.startswith('#'):
                m = re.match(r'#\s*([^:]+):\s*(.+)', stripped)
                if m:
                    meta[m.group(1).strip()] = m.group(2).strip()
                continue
            if not stripped:
                continue
            parts = stripped.split()
            if len(parts) == 2:
                try:
                    coord_lines.append((float(parts[0]), float(parts[1])))
                except ValueError:
                    continue

    if len(coord_lines) < 10:
        raise ValueError(f"Too few coordinate points ({len(coord_lines)}) in {filepath}")

    coords = normalise_airfoil_coordinates(np.array(coord_lines))

    # ── Parse estimated Reynolds from header ─────────────────────────
    for key in ('Est. Reynolds', 'Estimated Reynolds Number', 'estimated_reynolds'):
        if key in meta:
            try:
                re_str = meta[key].replace(',', '').replace('e+0', 'e+').replace('e-0', 'e-')
                meta['_estimated_re'] = float(re_str.split()[0])
                meta['_re_method'] = 'header'
                break
            except (ValueError, AttributeError):
                pass

    # ── Allometric estimation (§4) ───────────────────────────────────
    if '_estimated_re' not in meta:
        body_mass_kg = None
        wing_length_mm = 0.0
        wing_loading_proxy = 0.0

        for key in ('Body Mass', 'Body.Mass', 'body_mass_g'):
            if key in meta:
                try:
                    mass_g = float(meta[key].replace('g', '').strip())
                    body_mass_kg = mass_g / 1000.0
                    break
                except (ValueError, AttributeError):
                    pass

        for key in ('Wing Length', 'Wing.Length'):
            if key in meta:
                try:
                    wing_length_mm = float(meta[key].replace('mm', '').strip())
                    break
                except (ValueError, AttributeError):
                    pass

        for key in ('Wing Loading Proxy', 'Wing.Loading.Proxy'):
            if key in meta:
                try:
                    wing_loading_proxy = float(meta[key])
                    break
                except (ValueError, AttributeError):
                    pass

        re_est, method = estimate_reynolds_allometric(
            body_mass_kg, wing_length_mm, wing_loading_proxy)
        meta['_estimated_re'] = re_est
        meta['_re_method'] = method

    # ── Species / category from filename ─────────────────────────────
    filename = Path(filepath).stem
    if 'Species' not in meta:
        parts = filename.split('_')
        if len(parts) >= 3:
            meta['Species'] = '_'.join(parts[2:-1])

    category = Path(filepath).parent.name
    if category in ('diving', 'generalist', 'hovering',
                     'maneuvering', 'soaring', 'cruising'):
        meta['Flight Category'] = category

    # ── Geometry descriptors (§7) ────────────────────────────────────
    geo = extract_geometry_descriptors(coords)
    meta.update(geo)

    return coords, meta


# ---------------------------------------------------------------------------
# §2  IMPROVED STALL DETECTION
# ---------------------------------------------------------------------------

def detect_stall(alphas: list[float], cls: list[float]) -> tuple[float, float, str]:
    """
    Detect CLmax and stall angle using a multi-method approach.

    Methods (applied in parallel; the *earliest* stall trigger wins):
    ─────────────────────────────────────────────────────────────────
    A.  SLOPE DEGRADATION
        Compute dCL/dα via central differences.  The "linear region"
        slope is estimated from the α ∈ [0°, 6°] range.  Stall is
        declared when the local slope drops below 40 % of the linear
        slope *and* α > 4° (to avoid false triggers near α = 0).

    B.  CURVATURE SIGN CHANGE
        d²CL/dα² (second derivative) should be near zero in the linear
        region and become strongly negative at stall onset.  Stall is
        declared at the first α (> 4°) where d²CL/dα² < −0.003 /deg².

    C.  PEAK-DROP (v2 fallback)
        Find CLmax; stall angle is the first subsequent α where
        CL < 0.95 × CLmax.

    Parameters
    ----------
    alphas : list[float]   sorted ascending (degrees)
    cls    : list[float]   corresponding CL values

    Returns
    -------
    cl_max      : float
    stall_alpha : float
    method      : str     which detection method triggered
    """
    if len(cls) < 4:
        return (max(cls) if cls else 0.0), (alphas[-1] if alphas else 0.0), 'insufficient_data'

    a = np.array(alphas, dtype=float)
    cl = np.array(cls, dtype=float)

    # ── CLmax ────────────────────────────────────────────────────────
    i_peak = int(np.argmax(cl))
    cl_max = float(cl[i_peak])

    # ── Method A: slope degradation ──────────────────────────────────
    # dCL/dα via central differences (deg⁻¹)
    dcl_da = np.gradient(cl, a)

    # Linear-region slope: use α ∈ [0, 6] or first 4 points if too few
    linear_mask = (a >= 0) & (a <= 6)
    if np.sum(linear_mask) >= 2:
        slope_linear = float(np.mean(dcl_da[linear_mask]))
    else:
        slope_linear = float(np.mean(dcl_da[:min(4, len(dcl_da))]))

    slope_threshold = 0.15 * slope_linear  # Much closer to real stall behavior

    stall_a_slope = None
    for i in range(i_peak, len(a)):
        if a[i] > 4.0 and dcl_da[i] < slope_threshold:
            stall_a_slope = float(a[i])
            break

    # ── Method B: curvature ──────────────────────────────────────────
    d2cl_da2 = np.gradient(dcl_da, a)
    stall_a_curv = None
    for i in range(len(a)):
        if a[i] > 4.0 and d2cl_da2[i] < -0.003:
            stall_a_curv = float(a[i])
            break

    # ── Method C: peak-drop (v2 fallback) ────────────────────────────
    stall_a_peak = float(a[i_peak])
    threshold_95 = cl_max * 0.95
    for i in range(i_peak + 1, len(cl)):
        if cl[i] < threshold_95:
            stall_a_peak = float(a[i])
            break

    # ── Choose by priority: peak_drop > curvature > slope ────────────
    # Prefer peak-drop method as most physically meaningful
    if stall_a_peak is not None:
        stall_alpha = stall_a_peak
        method = 'peak_drop'
    elif stall_a_curv is not None:
        stall_alpha = stall_a_curv
        method = 'curvature'
    elif stall_a_slope is not None:
        stall_alpha = stall_a_slope
        method = 'slope_degradation'
    else:
        stall_alpha = float(a[i_peak])
        method = 'fallback'

    # Apply physical constraint: stall angle should be between 8° and 18°
    stall_alpha = np.clip(stall_alpha, 8.0, 18.0)

    return cl_max, stall_alpha, method


# ---------------------------------------------------------------------------
# §6  ADDITIONAL PERFORMANCE METRICS
# ---------------------------------------------------------------------------

def compute_advanced_metrics(df: pd.DataFrame) -> dict:
    """
    Compute endurance parameter, moment stability, and drag-bucket width
    from a single-bird DataFrame (all Re and α).

    Returns dict of scalar metrics.
    """
    metrics = {}

    # ── Endurance parameter: max CL^1.5 / CD ────────────────────────
    cl_pos = df[df['CL'] > 0].copy()
    if not cl_pos.empty:
        cl_pos = cl_pos.copy()
        cl_pos['endurance'] = cl_pos['CL'] ** 1.5 / cl_pos['CD']
        metrics['max_endurance_param'] = safe_float(cl_pos['endurance'].max())
        best_end = cl_pos.loc[cl_pos['endurance'].idxmax()]
        metrics['endurance_alpha'] = safe_float(best_end['alpha'])
        metrics['endurance_Re'] = safe_float(best_end['Re'])
    else:
        metrics['max_endurance_param'] = 0.0
        metrics['endurance_alpha'] = 0.0
        metrics['endurance_Re'] = 0.0

    # ── Pitching-moment stability: dCM/dCL ───────────────────────────
    # Negative dCM/dCL indicates static stability about the quarter-chord.
    # Compute per-Re and take the median.
    cm_slopes = []
    for _, grp in df.groupby('Re'):
        grp_s = grp.sort_values('alpha')
        if len(grp_s) >= 4:
            cl_arr = grp_s['CL'].values
            cm_arr = grp_s['CM'].values
            # Linear region only (α 0–8°)
            mask = grp_s['alpha'].between(0, 8)
            if mask.sum() >= 3:
                slope, _, _, _, _ = scipy_stats.linregress(
                    cl_arr[mask.values], cm_arr[mask.values])
                cm_slopes.append(slope)
    metrics['dCM_dCL'] = float(np.median(cm_slopes)) if cm_slopes else 0.0
    metrics['is_statically_stable'] = metrics['dCM_dCL'] < 0

    # ── Drag-bucket width ────────────────────────────────────────────
    # Δα over which CD < 1.1 × CD_min, at the Re nearest the design Re.
    bucket_widths = []
    for _, grp in df.groupby('Re'):
        grp_s = grp.sort_values('alpha')
        cd_min_local = grp_s['CD'].min()
        in_bucket = grp_s['CD'] < 1.1 * cd_min_local
        if in_bucket.any():
            a_in = grp_s.loc[in_bucket, 'alpha']
            bucket_widths.append(float(a_in.max() - a_in.min()))
    metrics['drag_bucket_width'] = float(np.median(bucket_widths)) if bucket_widths else 0.0

    return metrics


