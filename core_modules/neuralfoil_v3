# CORE SIMULATION
# ---------------------------------------------------------------------------

def run_simulation_for_file(
    dat_file:   str,
    reynolds:   list[float] = REYNOLDS_NUMBERS,
    alphas:     list[float] = ALPHAS,
    model_size: str         = MODEL_SIZE,
) -> tuple[list[dict], dict]:
    """
    Run the full alpha × Re test matrix for a single .dat file.

    Returns
    -------
    results    : list[dict]   One dict per (alpha, Re) condition.
    file_meta  : dict         Parsed header metadata + geometry descriptors.
    """
    coords, file_meta = load_dat_file(dat_file)
    bird_name = file_meta.get('Species', Path(dat_file).stem)
    category = file_meta.get('Flight Category', Path(dat_file).parent.name)
    results = []

    for re_val in reynolds:
        # §1  drag correction factor for this Re
        k_cd = get_drag_correction(re_val)

        for alpha in alphas:
            try:
                aero = nf.get_aero_from_coordinates(
                    coordinates=coords,
                    alpha=alpha,
                    Re=re_val,
                    model_size=model_size,
                )

                cl = safe_float(aero.get('CL', 0.0))
                cd_raw = safe_float(aero.get('CD', 1e-6))
                cm = safe_float(aero.get('CM', 0.0))
                confidence = safe_float(aero.get('analysis_confidence', 0.0))
                top_xtr = safe_float(aero.get('Top_Xtr', 1.0))
                bot_xtr = safe_float(aero.get('Bot_Xtr', 1.0))

                # §1  Apply drag correction
                cd_corrected = max(abs(cd_raw) * k_cd, 1e-7)

                # §3  Plausibility check
                plausible = True
                if cd_corrected < CD_MIN_PLAUSIBLE:
                    cd_corrected = CD_MIN_PLAUSIBLE  # floor
                    plausible = False
                if abs(cl) > CL_MAX_PLAUSIBLE:
                    plausible = False

                ld = cl / cd_corrected

                if abs(ld) > LD_MAX_PLAUSIBLE:
                    ld = np.sign(ld) * LD_MAX_PLAUSIBLE
                    plausible = False

                results.append({
                    'bird_name':           bird_name,
                    'category':            category,
                    'file_path':           dat_file,
                    'alpha':               float(alpha),
                    'Re':                  float(re_val),
                    'CL':                  cl,
                    'CD_raw':              abs(cd_raw),
                    'CD':                  cd_corrected,
                    'CD_correction':       k_cd,
                    'CM':                  cm,
                    'LD_ratio':            ld,
                    'analysis_confidence': confidence,
                    'low_confidence':      confidence < CONFIDENCE_THRESHOLD,
                    'plausible':           plausible,
                    'Top_Xtr':             top_xtr,
                    'Bot_Xtr':             bot_xtr,
                })

            except Exception:
                continue

    return results, file_meta


def build_summary(
    bird_name:  str,
    category:   str,
    dat_file:   str,
    df:         pd.DataFrame,
    file_meta:  dict,
) -> dict | None:
    """
    Compute summary statistics for one bird from its full result DataFrame.

    Only *plausible* data points are used for headline metrics (§3).
    """
    if df.empty:
        return None

    # §3  Filter to plausible points for headline metrics
    dfp = df[df['plausible']].copy()
    if dfp.empty:
        dfp = df.copy()  # fall back to all data if nothing is plausible

    total_points = len(df)
    plausible_frac = len(dfp) / total_points if total_points > 0 else 0.0

    # ── Subsets by flight regime ─────────────────────────────────────
    neg_alpha  = dfp[dfp['alpha'] < 0]
    cruise     = dfp[dfp['alpha'].between(0, 2)]
    design     = dfp[dfp['alpha'] == 4]
    climb      = dfp[dfp['alpha'].between(8, 12)]
    high_alpha = dfp[dfp['alpha'] >= 14]

    # ── Best L/D row ─────────────────────────────────────────────────
    idx_best = dfp['LD_ratio'].idxmax()
    best_row = dfp.loc[idx_best]

    # ── Per-Re L/D ───────────────────────────────────────────────────
    re_ld = {}
    for re_val, grp in dfp.groupby('Re'):
        re_ld[f'LD_at_Re_{re_val:.0e}'] = safe_float(grp['LD_ratio'].max())

    # ── §2  Improved stall detection ─────────────────────────────────
    estimated_re = file_meta.get('_estimated_re', 1e5)
    re_method = file_meta.get('_re_method', 'unknown')
    re_for_stall = min(REYNOLDS_NUMBERS, key=lambda r: abs(r - estimated_re))
    stall_df = dfp[dfp['Re'] == re_for_stall].sort_values('alpha')

    cl_max, stall_alpha, stall_method = detect_stall(
        stall_df['alpha'].tolist(),
        stall_df['CL'].tolist(),
    )

    # ── Design-point performance at estimated Re ─────────────────────
    design_re_df = dfp[dfp['Re'] == re_for_stall]
    design_re_ld = safe_float(design_re_df['LD_ratio'].max()) if not design_re_df.empty else 0.0
    design_re_cl = (safe_float(design_re_df.loc[design_re_df['LD_ratio'].idxmax(), 'CL'])
                    if not design_re_df.empty else 0.0)

    # ── §6  Advanced metrics ─────────────────────────────────────────
    adv = compute_advanced_metrics(dfp)

    # ── Geometry (§7) ────────────────────────────────────────────────
    t_over_c = file_meta.get('t_over_c', 0.0)
    max_camber = file_meta.get('max_camber', 0.0)
    camber_loc = file_meta.get('camber_loc', 0.0)

    summary = {
        'bird_name':            bird_name,
        'category':             category,
        'file_path':            dat_file,

        # Global bests (plausible only)
        'max_LD':               safe_float(dfp['LD_ratio'].max()),
        'avg_LD':               safe_float(dfp['LD_ratio'].mean()),
        'LD_std':               safe_float(dfp['LD_ratio'].std()),
        'max_CL':               safe_float(dfp['CL'].max()),
        'min_CD':               safe_float(dfp['CD'].min()),

        # Regime-specific L/D
        'neg_alpha_LD':         safe_float(neg_alpha['LD_ratio'].mean())  if not neg_alpha.empty  else 0.0,
        'cruise_LD':            safe_float(cruise['LD_ratio'].mean())     if not cruise.empty     else 0.0,
        'design_LD':            safe_float(design['LD_ratio'].mean())     if not design.empty     else 0.0,
        'climb_LD':             safe_float(climb['LD_ratio'].mean())      if not climb.empty      else 0.0,
        'high_alpha_LD':        safe_float(high_alpha['LD_ratio'].mean()) if not high_alpha.empty else 0.0,

        # Stall characteristics (§2)
        'CL_max':               cl_max,
        'stall_alpha':          stall_alpha,
        'stall_method':         stall_method,

        # Reynolds (§4)
        'estimated_Re':         estimated_re,
        'Re_method':            re_method,
        'design_point_Re':      re_for_stall,
        'design_point_LD':      design_re_ld,
        'design_point_CL':      design_re_cl,

        # Best operating point
        'best_alpha':           safe_float(best_row['alpha']),
        'best_Re':              safe_float(best_row['Re']),

        # Consistency
        'LD_CoV':               safe_float(
                                    dfp['LD_ratio'].std() /
                                    (dfp['LD_ratio'].mean() + 1e-6)
                                ),

        # Quality
        'avg_confidence':       safe_float(df['analysis_confidence'].mean()),
        'low_conf_fraction':    safe_float(df['low_confidence'].mean()),
        'plausible_fraction':   plausible_frac,
        'conditions_tested':    total_points,

        # §6  Advanced
        'max_endurance_param':  adv['max_endurance_param'],
        'endurance_alpha':      adv['endurance_alpha'],
        'endurance_Re':         adv['endurance_Re'],
        'dCM_dCL':              adv['dCM_dCL'],
        'is_statically_stable': adv['is_statically_stable'],
        'drag_bucket_width':    adv['drag_bucket_width'],

        # §7  Geometry
        't_over_c':             t_over_c,
        'max_camber':           max_camber,
        'camber_loc':           camber_loc,

        **re_ld,
    }

    return summary


