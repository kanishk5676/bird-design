def safe_float(value) -> float:
    """Convert any value (scalar, list, ndarray) to a Python float."""
    if value is None:
        return 0.0
    if isinstance(value, np.ndarray):
        if value.ndim == 0:
            return float(value.item())
        else:
            flat = value.flatten()
            return float(flat[0]) if len(flat) > 0 else 0.0
    if isinstance(value, (list, tuple)):
        return float(value[0]) if len(value) > 0 else 0.0
    if hasattr(value, '__iter__') and not isinstance(value, (str, bytes)):
        try:
            arr = np.asarray(value).flatten()
            return float(arr[0]) if len(arr) > 0 else 0.0
        except (TypeError, ValueError, IndexError):
            pass
    try:
        return float(value)
    except (TypeError, ValueError, AttributeError):
        return 0.0


def normalise_airfoil_coordinates(coords: np.ndarray) -> np.ndarray:
    """
    Re-normalise (x, y) airfoil coordinates so that chord = 1.0.

    NeuralFoil is robust to non-unit chord but returns coefficients
    referenced to whatever chord length it detects.  Normalising first
    ensures that every bird in the database uses the same reference length,
    which is essential for valid cross-bird L/D comparisons.
    """
    x = coords[:, 0]
    chord = x.max() - x.min()
    if chord < 1e-9:
        raise ValueError("Degenerate airfoil: chord length is effectively zero.")
    x_le = x.min()
    normalised = coords.copy()
    normalised[:, 0] = (coords[:, 0] - x_le) / chord
    normalised[:, 1] = coords[:, 1] / chord
    return normalised


def extract_geometry_descriptors(coords: np.ndarray) -> dict:
    """
    Extract thickness-to-chord ratio, max camber, and camber position
    from normalised airfoil coordinates.

    Assumes standard Selig ordering: upper surface (TE→LE) then
    lower surface (LE→TE).  Falls back to a simple split at x_min
    if the ordering is non-standard.
    """
    x = coords[:, 0]
    y = coords[:, 1]

    # Find leading edge (minimum x)
    i_le = int(np.argmin(x))

    # Split into upper and lower surfaces
    x_upper = x[:i_le + 1][::-1]
    y_upper = y[:i_le + 1][::-1]
    x_lower = x[i_le:]
    y_lower = y[i_le:]

    # Interpolate both surfaces onto a common x grid
    x_common = np.linspace(0.0, 1.0, 201)
    if len(x_upper) < 3 or len(x_lower) < 3:
        return {'t_over_c': 0.0, 'max_camber': 0.0, 'camber_loc': 0.0}

    y_up_interp = np.interp(x_common, x_upper, y_upper)
    y_lo_interp = np.interp(x_common, x_lower, y_lower)

    thickness = y_up_interp - y_lo_interp
    camber = (y_up_interp + y_lo_interp) / 2.0

    t_over_c = float(np.max(thickness))
    max_camber = float(np.max(np.abs(camber)))
    camber_loc = float(x_common[np.argmax(np.abs(camber))])

    return {
        't_over_c': t_over_c,
        'max_camber': max_camber,
        'camber_loc': camber_loc,
    }


# ── §4  REYNOLDS ESTIMATION ─────────────────────────────────────────────

def estimate_reynolds_allometric(
    body_mass_kg: float | None = None,
    wing_length_mm: float = 0.0,
    wing_loading_proxy: float = 0.0,
) -> tuple[float, str]:
    """
    Estimate Reynolds number from morphological data.

    Preferred method (when body mass is available):
        V_mp = 4.09 · m^0.21   (Pennycuick 2008, minimum-power speed)
        b    = 1.17 · m^0.39   (wingspan allometry, Pennycuick 2008)
        c    = b / AR           (chord from aspect ratio; assume AR ≈ 7)
        Re   = ρ V c / μ

    Fallback (heuristic, flagged):
        Uses the v2 velocity model when mass is not available.

    Returns
    -------
    re      : float    Estimated Reynolds number, clipped to [1e4, 2e6].
    method  : str      'allometric' or 'heuristic' — for transparency.
    """
    RHO_OVER_MU = 67_679.0  # ρ/μ at sea level, 15 °C  (1.225 / 1.81e-5)

    if body_mass_kg is not None and body_mass_kg > 0:
        # Pennycuick (2008) minimum-power speed
        v_mp = 4.09 * body_mass_kg ** 0.21                 # m/s
        # Wingspan allometry (Pennycuick 2008)
        b = 1.17 * body_mass_kg ** 0.39                    # m
        # Assume aspect ratio ~ 7 (typical passerine–raptor range 5–10)
        ar = 7.0
        chord = b / ar                                      # m
        re = RHO_OVER_MU * v_mp * chord
        return float(np.clip(re, 1e4, 2e6)), 'allometric'

    # ── Fallback heuristic (same as v2, but flagged) ─────────────
    if wing_length_mm > 0:
        velocity = max(5.0, min(30.0,
                                8.0 + 200.0 * wing_loading_proxy
                                + 0.05 * wing_length_mm))
        chord_m = wing_length_mm / 1000.0 * 0.15
        re = RHO_OVER_MU * velocity * chord_m
        return float(np.clip(re, 1e4, 2e6)), 'heuristic'

    return 1e5, 'default'


