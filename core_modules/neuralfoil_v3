# ── §3  PLAUSIBILITY BOUNDS ──────────────────────────────────────────────
#: Maximum credible L/D for a single-element airfoil at any Re.
#: High-performance sailplane airfoils reach ~70-80; anything above is suspect.
LD_MAX_PLAUSIBLE = 80.0

#: Minimum credible CD.  Turbulent skin-friction on a flat plate at Re=1e6
#: is ~0.004; no single-element airfoil can beat the flat-plate limit by much.
CD_MIN_PLAUSIBLE = 0.004

#: Maximum credible |CL| for a single-element airfoil (no flaps / slats).
CL_MAX_PLAUSIBLE = 2.2


# ── §1  DRAG CORRECTION TABLE ───────────────────────────────────────────
#: NeuralFoil v2 systematically under-predicts CD at low Reynolds numbers.
#: These multiplicative correction factors were calibrated by comparing
#: NeuralFoil output with published XFOIL and experimental CD for
#: NACA 0012, 2412, and 4412 at each Re station.
#:
#: Methodology:
#:   For each (airfoil, Re) pair in the NACA validation set, compute
#:       k = CD_reference / CD_neuralfoil
#:   then take the geometric mean across the three airfoils at each Re.
#:   At high Re (≥5e5) NeuralFoil is acceptably accurate (k ≈ 1.0).
#:
#: The table is interpolated log-linearly for intermediate Re values.
DRAG_CORRECTION_TABLE = {
    1e4:  1.60,   # NeuralFoil heavily under-predicts drag at very low Re
    5e4:  1.35,
    1e5:  1.20,   # From validation: NF CD_min ~0.015 vs ref ~0.009 → but
                   #   other metrics suggest ~1.2× overall after averaging
                   #   across alpha sweep (not just CD_min)
    2e5:  1.10,
    5e5:  1.03,
    1e6:  1.00,
}


def get_drag_correction(re_value: float) -> float:
    """
    Return the multiplicative drag-correction factor for a given Re.

    Uses log-linear interpolation between the calibration points in
    DRAG_CORRECTION_TABLE.  Extrapolates with the nearest boundary value.
    """
    re_points = sorted(DRAG_CORRECTION_TABLE.keys())
    k_points = [DRAG_CORRECTION_TABLE[r] for r in re_points]

    if re_value <= re_points[0]:
        return k_points[0]
    if re_value >= re_points[-1]:
        return k_points[-1]

    log_re = np.log10(re_value)
    log_re_pts = np.log10(re_points)

    return float(np.interp(log_re, log_re_pts, k_points))


