def generate_report(
    summary_df:       pd.DataFrame,
    category_leaders: dict,
    output_dir:       Path,
    val_df:           pd.DataFrame | None = None,
    corr_df:          pd.DataFrame | None = None,
) -> None:
    """Write a structured text report to disk."""
    path = output_dir / "comprehensive_report.txt"

    with open(path, 'w') as f:

        def w(text=""):
            f.write(text + "\n")

        w("=" * 72)
        w("COMPREHENSIVE BIRD AIRFOIL AERODYNAMIC ANALYSIS REPORT  (v3)")
        w("=" * 72)
        w()
        w(f"Total airfoils analysed : {len(summary_df)}")
        w(f"Categories              : {', '.join(summary_df['category'].unique())}")
        w(f"Alpha sweep             : {min(ALPHAS)}° to {max(ALPHAS)}° in 2° steps")
        w(f"Reynolds number sweep   : {', '.join(f'{r:.0e}' for r in REYNOLDS_NUMBERS)}")
        w(f"Conditions per airfoil  : {len(ALPHAS) * len(REYNOLDS_NUMBERS)}")
        w(f"Plausibility bounds     : L/D ≤ {LD_MAX_PLAUSIBLE}, "
          f"CD ≥ {CD_MIN_PLAUSIBLE}, CL ≤ {CL_MAX_PLAUSIBLE}")
        w(f"Drag correction         : Re-dependent "
          f"({min(DRAG_CORRECTION_TABLE.values()):.2f}–"
          f"{max(DRAG_CORRECTION_TABLE.values()):.2f}×)")
        w()

        # ── Validation summary ───────────────────────────────────────
        if val_df is not None and not val_df.empty:
            n_pass = val_df['passed'].sum()
            n_total = len(val_df)
            w("NEURALFOIL VALIDATION (with drag correction)")
            w("-" * 72)
            w(f"  Checks: {n_total}   Passed: {n_pass}   Failed: {n_total - n_pass}")
            for _, row in val_df.iterrows():
                status = '✓' if row['passed'] else '✗'
                w(f"  {status}  {row['airfoil']}  Re={row['Re']:.0e}  "
                  f"{row['metric']:>14s}: NF={row['NF_value']:.4f}  "
                  f"Ref={row['ref_value']}±{row['tolerance']}")
            w()
            # Error summary
            for metric in ['CLmax', 'stall_alpha', 'CL_slope', 'CD_min']:
                sub = val_df[val_df['metric'] == metric]
                if sub.empty:
                    continue
                mae = sub['abs_error'].mean()
                rmse = np.sqrt((sub['error'] ** 2).mean())
                bias = sub['error'].mean()
                w(f"  {metric:>14s}:  MAE={mae:.4f}  RMSE={rmse:.4f}  Bias={bias:+.4f}")
            w()

        # ── Overall stats ────────────────────────────────────────────
        w("OVERALL PERFORMANCE STATISTICS (filtered)")
        w("-" * 72)
        best_idx = summary_df['max_LD'].idxmax()
        w(f"Best global L/D : {summary_df['max_LD'].max():.2f}  "
          f"({summary_df.loc[best_idx, 'bird_name']})")
        w(f"Average max L/D : {summary_df['max_LD'].mean():.2f} "
          f"± {summary_df['max_LD'].std():.2f}")
        w(f"Average CLmax   : {summary_df['CL_max'].mean():.3f} "
          f"± {summary_df['CL_max'].std():.3f}")
        w(f"Average stall α : {summary_df['stall_alpha'].mean():.1f}° "
          f"± {summary_df['stall_alpha'].std():.1f}°")
        if 'plausible_fraction' in summary_df:
            w(f"Avg plausible % : {summary_df['plausible_fraction'].mean() * 100:.1f}%")
        w()

        # ── Stall method distribution ────────────────────────────────
        if 'stall_method' in summary_df.columns:
            w("STALL DETECTION METHOD DISTRIBUTION")
            w("-" * 72)
            for method, count in summary_df['stall_method'].value_counts().items():
                w(f"  {method:<25s}: {count:>6d}  "
                  f"({count / len(summary_df) * 100:.1f}%)")
            w()

        # ── Re estimation method distribution ────────────────────────
        if 'Re_method' in summary_df.columns:
            w("REYNOLDS ESTIMATION METHOD DISTRIBUTION")
            w("-" * 72)
            for method, count in summary_df['Re_method'].value_counts().items():
                w(f"  {method:<25s}: {count:>6d}  "
                  f"({count / len(summary_df) * 100:.1f}%)")
            w()

        # ── Per-category details ─────────────────────────────────────
        for category, data in category_leaders.items():
            leader = data['leader']
            w()
            w("=" * 72)
            w(f"CATEGORY: {category.upper()}")
            w("=" * 72)
            w()
            w(f"  TOP PERFORMER: {leader['bird_name']}")
            w("-" * 72)
            w(f"  Max L/D (filtered)   : {safe_float(leader['max_LD']):.2f}")
            w(f"  Weighted avg L/D     : {safe_float(leader['avg_LD']):.2f}")
            w(f"  Cruise L/D (α 0–2°)  : {safe_float(leader['cruise_LD']):.2f}")
            w(f"  Climb L/D (α 8–12°)  : {safe_float(leader['climb_LD']):.2f}")
            w(f"  CLmax                : {safe_float(leader['CL_max']):.3f}")
            w(f"  Stall angle          : {safe_float(leader['stall_alpha']):.1f}°")
            w(f"  Stall method         : {leader.get('stall_method', 'unknown')}")
            w(f"  Minimum CD           : {safe_float(leader['min_CD']):.5f}")
            w(f"  Best alpha           : {safe_float(leader['best_alpha']):.1f}°")
            w(f"  Best Re              : {safe_float(leader['best_Re']):.2e}")
            w(f"  Plausible fraction   : {safe_float(leader.get('plausible_fraction', 0)) * 100:.1f}%")
            w(f"  Endurance CL^1.5/CD  : {safe_float(leader.get('max_endurance_param', 0)):.2f}")
            w(f"  dCM/dCL              : {safe_float(leader.get('dCM_dCL', 0)):.4f}")
            w(f"  Drag bucket width    : {safe_float(leader.get('drag_bucket_width', 0)):.1f}°")
            w(f"  t/c                  : {safe_float(leader.get('t_over_c', 0)):.3f}")
            w(f"  max camber           : {safe_float(leader.get('max_camber', 0)):.3f}")
            w()

            w("  WHY THIS AIRFOIL EXCELS:")
            for i, reason in enumerate(data['performance_reasons'], 1):
                words = reason.split()
                lines = []
                line = f"  {i}. "
                for word in words:
                    if len(line) + len(word) + 1 > 72:
                        lines.append(line)
                        line = "     "
                    line += word + " "
                lines.append(line)
                w("\n".join(lines))
            w()

            stats = data['category_stats']
            w(f"  Category stats: n={stats['count']}, "
              f"mean L/D={stats['mean_LD']:.2f}±{stats['std_LD']:.2f}, "
              f"mean CLmax={stats['mean_CL']:.3f}, "
              f"mean stall={stats['mean_stall']:.1f}°±{stats.get('std_stall', 0):.1f}°")
            w(f"  Avg thickness={stats.get('mean_t_over_c', 0):.3f}, "
              f"Avg camber={stats.get('mean_camber', 0):.3f}, "
              f"Plausible={stats.get('plausible_pct', 0):.1f}%")
            w()

            w("  Top 3 — Overall L/D:")
            for i, b in enumerate(data['top_3_overall'], 1):
                w(f"    {i}. {b['bird_name']}: L/D = {b['max_LD']:.2f}")
            w("  Top 3 — CLmax / Stall:")
            for i, b in enumerate(data['top_3_cl_max'], 1):
                w(f"    {i}. {b['bird_name']}: CLmax = {b['CL_max']:.3f}  "
                  f"stall α = {b['stall_alpha']:.1f}°")
            w("  Top 3 — Most Consistent:")
            for i, b in enumerate(data['top_3_consistent'], 1):
                w(f"    {i}. {b['bird_name']}: L/D CoV = {b['LD_CoV']:.3f}")

        # ── Champion summary table ───────────────────────────────────
        w()
        w("=" * 72)
        w("CATEGORY CHAMPION SUMMARY")
        w("=" * 72)
        w(f"{'Category':<18} {'Champion':<30} {'L/D':>6} {'CLmax':>7} "
          f"{'Stall°':>7} {'t/c':>6} {'Camber':>7}")
        w("-" * 72)
        for cat, data in category_leaders.items():
            ldr = data['leader']
            w(f"{cat:<18} {str(ldr['bird_name'])[:29]:<30} "
              f"{safe_float(ldr['max_LD']):6.1f} "
              f"{safe_float(ldr['CL_max']):7.3f} "
              f"{safe_float(ldr['stall_alpha']):7.1f} "
              f"{safe_float(ldr.get('t_over_c', 0)):6.3f} "
              f"{safe_float(ldr.get('max_camber', 0)):7.3f}")

        # ── §7  Correlation highlights ───────────────────────────────
        if corr_df is not None and not corr_df.empty:
            sig = corr_df[(corr_df['spearman_p'] < 0.01) & (corr_df['n'] >= 20)]
            if not sig.empty:
                w()
                w("=" * 72)
                w("GEOMETRY–PERFORMANCE CORRELATIONS (Spearman, p < 0.01)")
                w("=" * 72)
                for _, row in sig.sort_values('spearman_p').head(20).iterrows():
                    w(f"  [{row['group']:>14s}]  {row['geometry']:<12s} vs "
                      f"{row['performance']:<22s}: "
                      f"r_s = {row['spearman_r']:+.3f}  (n={row['n']})")

    print(f"✓ Report saved to {path}")


