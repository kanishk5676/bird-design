def safe_float(value) -> float:
    """Convert any value (scalar, list, ndarray) to a Python float."""
    if value is None:
        return 0.0
    if isinstance(value, np.ndarray):
        if value.ndim == 0:
            return float(value.item())
        flat = value.flatten()
        return float(flat[0]) if len(flat) > 0 else 0.0
    if isinstance(value, (list, tuple)):
        return float(value[0]) if len(value) > 0 else 0.0
    if hasattr(value, '__iter__') and not isinstance(value, (str, bytes)):
        try:
            arr = np.asarray(value).flatten()
            return float(arr[0]) if len(arr) > 0 else 0.0
        except (TypeError, ValueError, IndexError):
            pass
    try:
        return float(value)
    except (TypeError, ValueError, AttributeError):
        return 0.0


def normalise_airfoil_coordinates(coords: np.ndarray) -> np.ndarray:
    """Re-normalise (x, y) airfoil coordinates so that chord = 1.0."""
    x = coords[:, 0]
    chord = x.max() - x.min()
    if chord < 1e-9:
        raise ValueError("Degenerate airfoil: chord length is effectively zero.")
    x_le = x.min()
    normalised = coords.copy()
    normalised[:, 0] = (coords[:, 0] - x_le) / chord
    normalised[:, 1] = coords[:, 1] / chord
    return normalised


def extract_geometry_descriptors(coords: np.ndarray) -> dict:
    """Extract t/c, max camber, and camber position."""
    x = coords[:, 0]
    y = coords[:, 1]
    i_le = int(np.argmin(x))

    x_upper = x[:i_le + 1][::-1]
    y_upper = y[:i_le + 1][::-1]
    x_lower = x[i_le:]
    y_lower = y[i_le:]

    x_common = np.linspace(0.0, 1.0, 201)
    if len(x_upper) < 3 or len(x_lower) < 3:
        return {'t_over_c': 0.0, 'max_camber': 0.0, 'camber_loc': 0.0}

    y_up_interp = np.interp(x_common, x_upper, y_upper)
    y_lo_interp = np.interp(x_common, x_lower, y_lower)

    thickness = y_up_interp - y_lo_interp
    camber = (y_up_interp + y_lo_interp) / 2.0

    return {
        't_over_c':   float(np.max(thickness)),
        'max_camber': float(np.max(np.abs(camber))),
        'camber_loc': float(x_common[np.argmax(np.abs(camber))]),
    }


def estimate_reynolds_allometric(
    body_mass_kg: float | None = None,
    wing_length_mm: float = 0.0,
    wing_loading_proxy: float = 0.0,
) -> tuple[float, str]:
    """Estimate Re from body mass (preferred) or wing morphology (fallback)."""
    RHO_OVER_MU = 67_679.0  # ρ/μ at sea level, 15 °C

    if body_mass_kg is not None and body_mass_kg > 0:
        v_mp = 4.09 * body_mass_kg ** 0.21       # Pennycuick 2008
        b = 1.17 * body_mass_kg ** 0.39          # wingspan allometry
        ar = 7.0                                  # typical bird AR
        chord = b / ar
        re = RHO_OVER_MU * v_mp * chord
        return float(np.clip(re, 1e4, 2e6)), 'allometric'

    if wing_length_mm > 0:
        velocity = max(5.0, min(30.0,
                                8.0 + 200.0 * wing_loading_proxy
                                + 0.05 * wing_length_mm))
        chord_m = wing_length_mm / 1000.0 * 0.15
        re = RHO_OVER_MU * velocity * chord_m
        return float(np.clip(re, 1e4, 2e6)), 'heuristic'

    return 1e5, 'default'


