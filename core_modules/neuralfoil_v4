REYNOLDS_NUMBERS = [1e4, 5e4, 1e5, 2e5, 5e5, 1e6]
ALPHAS = np.arange(-4, 20.5, 1.0).tolist()  # [-4, -3, ..., 20] — 1° steps
MODEL_SIZE = "xxlarge"
CONFIDENCE_THRESHOLD = 0.5

# ── Plausibility bounds (§3) ─────────────────────────────────────────────
LD_MAX_PLAUSIBLE = 80.0      # cap for reporting
LD_RAW_FILTER_MAX = 120.0    # above this = NeuralFoil artifact, drop
CD_MIN_PLAUSIBLE = 0.004     # flat-plate skin-friction floor
CL_MAX_PLAUSIBLE = 2.2       # single-element airfoil limit
STALL_ALPHA_WINDOW = (4.0, 22.0)   # wide window; anything outside → flagged

# ── Number of birds to export in overall-top CSV ─────────────────────────
TOP_N_OVERALL = 25

# ── Drag correction (§1) ─────────────────────────────────────────────────
DRAG_CORRECTION_TABLE = {
    1e4:  1.60,
    5e4:  1.35,
    1e5:  1.20,
    2e5:  1.10,
    5e5:  1.03,
    1e6:  1.00,
}


def get_drag_correction(re_value: float) -> float:
    """Log-linear interpolation of the Re-dependent drag correction."""
    re_points = sorted(DRAG_CORRECTION_TABLE.keys())
    k_points = [DRAG_CORRECTION_TABLE[r] for r in re_points]

    if re_value <= re_points[0]:
        return k_points[0]
    if re_value >= re_points[-1]:
        return k_points[-1]

    return float(np.interp(np.log10(re_value), np.log10(re_points), k_points))


