def run_validation(output_dir: Path) -> pd.DataFrame:
    """Validate NeuralFoil against NACA 0012/2412/4412 reference data."""
    from collections import OrderedDict

    NACA_REF = OrderedDict({
        ('NACA_0012', 1e5): {'CLmax': (0.90, 0.12), 'stall_alpha': (11.0, 3.0),
                             'CL_slope': (0.105, 0.015), 'CD_min': (0.009, 0.004)},
        ('NACA_0012', 5e5): {'CLmax': (1.15, 0.15), 'stall_alpha': (14.0, 3.0),
                             'CL_slope': (0.11, 0.01),  'CD_min': (0.006, 0.003)},
        ('NACA_2412', 1e5): {'CLmax': (1.15, 0.15), 'stall_alpha': (13.0, 3.0),
                             'CL_slope': (0.105, 0.015), 'CD_min': (0.009, 0.004)},
        ('NACA_2412', 5e5): {'CLmax': (1.35, 0.15), 'stall_alpha': (15.0, 3.0),
                             'CL_slope': (0.11, 0.01),  'CD_min': (0.006, 0.003)},
        ('NACA_4412', 1e5): {'CLmax': (1.40, 0.20), 'stall_alpha': (12.0, 3.0),
                             'CL_slope': (0.105, 0.015), 'CD_min': (0.009, 0.004)},
        ('NACA_4412', 5e5): {'CLmax': (1.60, 0.20), 'stall_alpha': (14.0, 3.0),
                             'CL_slope': (0.11, 0.01),  'CD_min': (0.006, 0.003)},
    })

    def generate_naca_4digit(m, p, t, n=101):
        x = (1 - np.cos(np.linspace(0, np.pi, n))) / 2
        yt = 5 * t * (0.2969 * np.sqrt(x) - 0.1260 * x
                       - 0.3516 * x**2 + 0.2843 * x**3 - 0.1015 * x**4)
        if m == 0:
            xu, yu = x, yt
            xl, yl = x, -yt
        else:
            yc = np.where(x < p, m / p**2 * (2 * p * x - x**2),
                          m / (1 - p)**2 * ((1 - 2 * p) + 2 * p * x - x**2))
            dyc = np.where(x < p, 2 * m / p**2 * (p - x),
                           2 * m / (1 - p)**2 * (p - x))
            theta = np.arctan(dyc)
            xu = x - yt * np.sin(theta); yu = yc + yt * np.cos(theta)
            xl = x + yt * np.sin(theta); yl = yc - yt * np.cos(theta)
        return np.vstack([
            np.column_stack([xu[::-1], yu[::-1]]),
            np.column_stack([xl[1:], yl[1:]]),
        ])

    naca_coords = {
        'NACA_0012': generate_naca_4digit(0.00, 0.0, 0.12),
        'NACA_2412': generate_naca_4digit(0.02, 0.4, 0.12),
        'NACA_4412': generate_naca_4digit(0.04, 0.4, 0.12),
    }

    rows = []
    print("\nNEURALFOIL VALIDATION (with drag correction applied)")
    print("-" * 72)

    for (airfoil, re_val), ref_metrics in NACA_REF.items():
        coords = naca_coords[airfoil]
        k_cd = get_drag_correction(re_val)

        cls, cds_corr = [], []
        for alpha in ALPHAS:
            try:
                aero = nf.get_aero_from_coordinates(
                    coordinates=coords, alpha=alpha, Re=re_val, model_size=MODEL_SIZE)
                cl = safe_float(aero.get('CL', 0.0))
                cd = max(safe_float(aero.get('CD', 1e-6)) * k_cd, CD_MIN_PLAUSIBLE)
                cls.append(cl); cds_corr.append(cd)
            except Exception:
                cls.append(0.0); cds_corr.append(0.01)

        cl_max_nf, stall_nf, stall_method, _ = detect_stall(ALPHAS, cls)
        cd_min_nf = min(cds_corr)

        lin_mask = [(0 <= a <= 6) for a in ALPHAS]
        a_lin = np.array(ALPHAS)[lin_mask]
        cl_lin = np.array(cls)[lin_mask]
        cl_slope = float(np.polyfit(a_lin, cl_lin, 1)[0]) if len(a_lin) >= 2 else 0.0

        nf_values = {'CLmax': cl_max_nf, 'stall_alpha': stall_nf,
                     'CL_slope': cl_slope, 'CD_min': cd_min_nf}

        for metric, (ref_val, tol) in ref_metrics.items():
            nf_val = nf_values[metric]
            error = nf_val - ref_val
            passed = abs(error) <= tol
            status = '✓' if passed else '✗'
            print(f"  {status}  {airfoil}  Re={re_val:.0e}  {metric:>14s}: "
                  f"NF={nf_val:.4f}  Ref={ref_val}±{tol}")

            rows.append({
                'airfoil': airfoil, 'Re': re_val, 'metric': metric,
                'NF_value': nf_val, 'ref_value': ref_val, 'tolerance': tol,
                'error': error, 'abs_error': abs(error), 'passed': passed,
                'drag_correction': k_cd,
                'stall_method': stall_method if metric == 'stall_alpha' else '',
            })

    val_df = pd.DataFrame(rows)

    print("\nValidation error summary (after drag correction):")
    for metric in ['CLmax', 'stall_alpha', 'CL_slope', 'CD_min']:
        sub = val_df[val_df['metric'] == metric]
        mae = sub['abs_error'].mean()
        rmse = np.sqrt((sub['error'] ** 2).mean())
        bias = sub['error'].mean()
        n_pass = sub['passed'].sum(); n_total = len(sub)
        print(f"  {metric:>14s}:  MAE={mae:.4f}  RMSE={rmse:.4f}  "
              f"Bias={bias:+.4f}  Pass={n_pass}/{n_total}")

    val_df.to_csv(output_dir / "validation_results.csv", index=False)
    print(f"\n✓ Validation results saved to {output_dir / 'validation_results.csv'}")

    return val_df


