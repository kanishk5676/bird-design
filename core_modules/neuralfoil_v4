def analyze_category_leaders(
    summary_df: pd.DataFrame, detailed_df: pd.DataFrame, output_dir: Path,
) -> dict:
    leaders = {}

    for category in summary_df['category'].unique():
        cat = summary_df[summary_df['category'] == category]
        if cat.empty:
            continue

        # Prefer birds with plausible stall & no fallback when identifying the leader
        cat_good = cat.copy()
        if 'stall_plausible' in cat_good.columns:
            filtered = cat_good[cat_good['stall_plausible']]
            if not filtered.empty:
                cat_good = filtered
        if 'used_implausible_fallback' in cat_good.columns:
            filtered = cat_good[~cat_good['used_implausible_fallback']]
            if not filtered.empty:
                cat_good = filtered

        top_overall    = cat_good.nlargest(3, 'max_LD')
        top_cruise     = cat_good.nlargest(3, 'cruise_LD')
        top_climb      = cat_good.nlargest(3, 'climb_LD')
        top_stall      = cat_good.nlargest(3, 'CL_max')
        top_consistent = cat_good.nsmallest(3, 'LD_CoV')
        top_endurance  = cat_good.nlargest(3, 'max_endurance_param')

        leader = cat_good.loc[cat_good['max_LD'].idxmax()]
        leader_name = leader['bird_name']
        leader_det = detailed_df[detailed_df['bird_name'] == leader_name]
        reasons = build_performance_reasons(leader, leader_det, cat)

        leaders[category] = {
            'leader':              leader.to_dict(),
            'top_3_overall':       top_overall[['bird_name', 'max_LD', 'avg_LD']].to_dict('records'),
            'top_3_cruise':        top_cruise[['bird_name', 'cruise_LD']].to_dict('records'),
            'top_3_climb':         top_climb[['bird_name', 'climb_LD']].to_dict('records'),
            'top_3_cl_max':        top_stall[['bird_name', 'CL_max', 'stall_alpha']].to_dict('records'),
            'top_3_consistent':    top_consistent[['bird_name', 'LD_CoV']].to_dict('records'),
            'top_3_endurance':     top_endurance[['bird_name', 'max_endurance_param']].to_dict('records'),
            'performance_reasons': reasons,
            'category_stats': {
                'count':         int(len(cat)),
                'mean_LD':       float(cat['max_LD'].mean()),
                'std_LD':        float(cat['max_LD'].std()),
                'mean_CL':       float(cat['CL_max'].mean()),
                'mean_stall':    float(cat['stall_alpha'].mean()),
                'std_stall':     float(cat['stall_alpha'].std()),
                'mean_t_over_c': float(cat['t_over_c'].mean()) if 't_over_c' in cat else 0.0,
                'mean_camber':   float(cat['max_camber'].mean()) if 'max_camber' in cat else 0.0,
                'plausible_pct': float(cat['plausible_fraction'].mean() * 100) if 'plausible_fraction' in cat else 0.0,
            },
        }

    with open(output_dir / "category_leaders.pkl", 'wb') as f:
        pickle.dump(leaders, f)

    return leaders


def build_performance_reasons(leader, leader_det, category_df) -> list[str]:
    reasons = []
    cat_mean = safe_float(category_df['max_LD'].mean())
    cat_std = safe_float(category_df['max_LD'].std())
    ldr_ld = safe_float(leader['max_LD'])

    if ldr_ld > cat_mean + cat_std:
        pct = (ldr_ld - cat_mean) / (cat_mean + 1e-6) * 100
        reasons.append(f"Peak L/D of {ldr_ld:.1f} is {pct:.0f}% above the category "
                       f"mean ({cat_mean:.1f}), indicating an unusually efficient geometry.")

    if safe_float(leader['min_CD']) < safe_float(category_df['min_CD'].quantile(0.25)):
        reasons.append(f"Minimum drag coefficient {safe_float(leader['min_CD']):.5f} is "
                       f"in the bottom quartile, suggesting extensive laminar flow.")

    if safe_float(leader['CL_max']) > safe_float(category_df['CL_max'].quantile(0.75)):
        reasons.append(f"CLmax = {safe_float(leader['CL_max']):.3f} (top quartile), "
                       f"allowing efficient flight at lower speeds and higher load factors.")

    stall_a = safe_float(leader['stall_alpha'])
    cat_median_stall = safe_float(category_df['stall_alpha'].median())
    if stall_a > safe_float(category_df['stall_alpha'].quantile(0.75)):
        reasons.append(f"Stall delayed until {stall_a:.1f}°, well above category median "
                       f"({cat_median_stall:.1f}°), giving a wide usable AoA range.")

    if safe_float(leader['cruise_LD']) > safe_float(category_df['cruise_LD'].quantile(0.75)):
        reasons.append(f"Cruise L/D = {safe_float(leader['cruise_LD']):.1f} (α = 0–2°), "
                       f"top quartile — well suited to sustained level flight.")

    if ldr_ld > 0 and safe_float(leader['high_alpha_LD']) > 0.6 * ldr_ld:
        reasons.append(f"Retains {safe_float(leader['high_alpha_LD']) / ldr_ld * 100:.0f}% "
                       f"of peak L/D at α ≥ 14°, indicating a gentle, progressive stall.")

    if ('max_endurance_param' in leader.index and
        safe_float(leader['max_endurance_param']) >
            safe_float(category_df['max_endurance_param'].quantile(0.75))):
        reasons.append(f"Endurance CL^1.5/CD = {safe_float(leader['max_endurance_param']):.1f} "
                       f"(top quartile) — optimal for loiter / hovering missions.")

    if 'dCM_dCL' in leader.index and safe_float(leader['dCM_dCL']) < -0.05:
        reasons.append(f"Negative dCM/dCL = {safe_float(leader['dCM_dCL']):.3f} indicates "
                       f"inherent pitch stability, reducing trim drag.")

    t_c = safe_float(leader.get('t_over_c', 0))
    cam = safe_float(leader.get('max_camber', 0))
    cam_x = safe_float(leader.get('camber_loc', 0))
    if t_c > 0 and cam > 0:
        reasons.append(f"Geometry: t/c = {t_c * 100:.1f}%, max camber = {cam * 100:.1f}% "
                       f"at x/c = {cam_x * 100:.0f}% — links shape to observed performance.")

    if not reasons:
        reasons.append(f"Best overall L/D in category ({ldr_ld:.1f}) without a single "
                       f"dominant trait — balanced across all flight regimes.")

    return reasons


