def analyze_all_dat_files(
    directory_path: Path, output_dir: Path,
) -> tuple[pd.DataFrame, pd.DataFrame, dict, pd.DataFrame, pd.DataFrame]:
    output_dir.mkdir(parents=True, exist_ok=True)

    val_df = run_validation(output_dir)

    dat_files = sorted(directory_path.rglob("*.dat"))
    if not dat_files:
        print(f"\n✗  No .dat files found in {directory_path}")
        return pd.DataFrame(), pd.DataFrame(), {}, pd.DataFrame(), pd.DataFrame()

    print(f"\nFound {len(dat_files)} .dat files")
    print(f"Test matrix: {len(ALPHAS)} α × {len(REYNOLDS_NUMBERS)} Re "
          f"= {len(ALPHAS) * len(REYNOLDS_NUMBERS)} conditions per airfoil")
    print(f"Total simulations: {len(dat_files) * len(ALPHAS) * len(REYNOLDS_NUMBERS):,}")
    print(f"Drag correction: Re-dependent "
          f"({min(DRAG_CORRECTION_TABLE.values()):.2f}–"
          f"{max(DRAG_CORRECTION_TABLE.values()):.2f}×)")
    print(f"L/D handling: raw filter > {LD_RAW_FILTER_MAX}, reported cap = {LD_MAX_PLAUSIBLE}; "
          f"CD ≥ {CD_MIN_PLAUSIBLE}, |CL| ≤ {CL_MAX_PLAUSIBLE}\n")

    all_results, all_summaries, failed_files = [], [], []

    for dat_file in tqdm(dat_files, desc="Simulating airfoils"):
        try:
            file_results, file_meta = run_simulation_for_file(str(dat_file))
        except Exception as e:
            tqdm.write(f"  ✗ Failed {dat_file.name}: {e}")
            failed_files.append(str(dat_file))
            continue
        if not file_results:
            continue

        all_results.extend(file_results)
        df_bird = pd.DataFrame(file_results)
        bird_name = file_meta.get('Species', dat_file.stem)
        category = file_meta.get('Flight Category', dat_file.parent.name)
        summary = build_summary(bird_name, category, str(dat_file), df_bird, file_meta)
        if summary is not None:
            all_summaries.append(summary)

    if not all_results:
        print("✗  No successful simulations.")
        return pd.DataFrame(), pd.DataFrame(), {}, pd.DataFrame(), pd.DataFrame()

    detailed_df = pd.DataFrame(all_results)
    summary_df = pd.DataFrame(all_summaries)

    detailed_df.to_csv(output_dir / "detailed_analysis.csv", index=False)
    summary_df.to_csv(output_dir / "summary_analysis.csv", index=False)

    with open(output_dir / "detailed_results.pkl", 'wb') as f:
        pickle.dump(detailed_df.to_dict('records'), f)
    with open(output_dir / "summary_results.pkl", 'wb') as f:
        pickle.dump(summary_df.to_dict('records'), f)

    if failed_files:
        with open(output_dir / "failed_files.txt", 'w') as f:
            f.write('\n'.join(failed_files))
        print(f"\n⚠️  {len(failed_files)} files failed (see failed_files.txt)")

    corr_df = compute_geometry_correlations(summary_df, output_dir)

    category_leaders = analyze_category_leaders(summary_df, detailed_df, output_dir)
    champions_df, top_overall_df = export_champions(summary_df, category_leaders, output_dir)

    generate_report(summary_df, category_leaders, output_dir, val_df, corr_df)
    create_visualizations(summary_df, detailed_df, output_dir)

    return detailed_df, summary_df, category_leaders, champions_df, top_overall_df


