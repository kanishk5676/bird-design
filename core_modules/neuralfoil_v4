def create_visualizations(summary_df, detailed_df, output_dir):
    plt.style.use('seaborn-v0_8-darkgrid')

    # 1. L/D by category
    fig, ax = plt.subplots(figsize=(13, 6))
    order = (summary_df.groupby('category')['max_LD']
             .median().sort_values(ascending=False).index)
    summary_df.boxplot(column='max_LD', by='category', ax=ax,
                       positions=range(len(order)), showfliers=False)
    ax.set_xticklabels(order, rotation=20, ha='right')
    ax.set_xlabel('Flight category'); ax.set_ylabel('Maximum L/D (drag-corrected)')
    ax.set_title('L/D Distribution by Category')
    plt.suptitle(''); plt.tight_layout()
    plt.savefig(output_dir / 'ld_distribution_by_category.png', dpi=300); plt.close()

    # 2. CLmax by category
    fig, ax = plt.subplots(figsize=(13, 6))
    summary_df.boxplot(column='CL_max', by='category', ax=ax, showfliers=False)
    ax.set_xlabel('Flight category'); ax.set_ylabel('CLmax')
    ax.set_title('Maximum Lift Coefficient by Category')
    plt.suptitle(''); plt.tight_layout()
    plt.savefig(output_dir / 'clmax_by_category.png', dpi=300); plt.close()

    # 3. Stall angle
    fig, ax = plt.subplots(figsize=(13, 6))
    summary_df.boxplot(column='stall_alpha', by='category', ax=ax, showfliers=False)
    ax.set_xlabel('Flight category'); ax.set_ylabel('Stall angle (°)')
    ax.set_title('Stall Angle Distribution by Category (no hard clip)')
    plt.suptitle(''); plt.tight_layout()
    plt.savefig(output_dir / 'stall_angle_by_category.png', dpi=300); plt.close()

    # 4. Top-15 performers
    top15 = summary_df.nlargest(15, 'max_LD')
    cats = top15['category'].unique()
    cmap = plt.cm.tab10(np.linspace(0, 1, max(len(cats), 1)))
    cdict = dict(zip(cats, cmap))
    colors = [cdict[c] for c in top15['category']]
    fig, ax = plt.subplots(figsize=(14, 8))
    ax.barh(range(len(top15)), top15['max_LD'], color=colors)
    ax.set_yticks(range(len(top15)))
    ax.set_yticklabels([f"{n}  ({c})" for n, c in zip(top15['bird_name'], top15['category'])],
                       fontsize=8)
    ax.set_xlabel('Maximum L/D Ratio (drag-corrected)')
    ax.set_title('Top 15 Airfoil Performers')
    plt.tight_layout()
    plt.savefig(output_dir / 'top_performers.png', dpi=300); plt.close()

    # 5. L/D vs Re
    re_cols = [c for c in summary_df.columns if c.startswith('LD_at_Re_')]
    if re_cols:
        fig, ax = plt.subplots(figsize=(12, 6))
        for cat in summary_df['category'].unique():
            sub = summary_df[summary_df['category'] == cat]
            means = [sub[c].mean() for c in re_cols]
            re_vals = [float(c.split('_')[-1]) for c in re_cols]
            ax.semilogx(re_vals, means, marker='o', label=cat)
        ax.set_xlabel('Reynolds Number'); ax.set_ylabel('Mean max L/D (drag-corrected)')
        ax.set_title('L/D vs Reynolds Number by Category'); ax.legend()
        plt.tight_layout()
        plt.savefig(output_dir / 'ld_vs_reynolds.png', dpi=300); plt.close()

    # 6. Correlation matrix
    corr_cols = [c for c in ['max_LD', 'cruise_LD', 'climb_LD', 'high_alpha_LD',
                             'CL_max', 'stall_alpha', 'min_CD', 'LD_CoV',
                             'max_endurance_param', 'drag_bucket_width', 'dCM_dCL']
                 if c in summary_df.columns]
    corr = summary_df[corr_cols].corr()
    fig, ax = plt.subplots(figsize=(12, 10))
    sns.heatmap(corr, annot=True, fmt='.2f', cmap='coolwarm', center=0, ax=ax, square=True)
    ax.set_title('Performance Metrics Correlation')
    plt.tight_layout()
    plt.savefig(output_dir / 'correlation_matrix.png', dpi=300); plt.close()

    # 7. CL-α polars
    categories = sorted(summary_df['category'].unique())
    n_cats = len(categories)
    n_cols = min(3, n_cats); n_rows = (n_cats + n_cols - 1) // n_cols
    fig, axes = plt.subplots(n_rows, n_cols, figsize=(6 * n_cols, 5 * n_rows), squeeze=False)
    axes_flat = axes.flatten()
    ax_i = -1
    for ax_i, cat in enumerate(categories):
        ax = axes_flat[ax_i]
        cat_sum = summary_df[summary_df['category'] == cat]
        if cat_sum.empty:
            continue
        leader_name = cat_sum.loc[cat_sum['max_LD'].idxmax(), 'bird_name']
        leader_det = detailed_df[detailed_df['bird_name'] == leader_name]
        for re_val, grp in leader_det.groupby('Re'):
            grp_sorted = grp.sort_values('alpha')
            ax.plot(grp_sorted['alpha'], grp_sorted['CL'],
                    label=f"Re={re_val:.0e}", linewidth=1.2)
        ax.axvline(x=0, color='grey', linewidth=0.5, linestyle='--')
        ax.set_title(f"{cat} — {leader_name[:22]}", fontsize=9)
        ax.set_xlabel('α (°)'); ax.set_ylabel('CL')
        ax.legend(fontsize=6)
    for j in range(ax_i + 1, len(axes_flat)):
        axes_flat[j].set_visible(False)
    plt.suptitle('CL-α Polars for Category Leaders (all Re)', fontsize=11)
    plt.tight_layout()
    plt.savefig(output_dir / 'cl_alpha_polars.png', dpi=300); plt.close()

    # 8. Geometry vs performance
    geo_perf_pairs = [
        ('t_over_c',   'max_LD',              't/c',        'Max L/D'),
        ('max_camber', 'CL_max',              'Max camber', 'CLmax'),
        ('t_over_c',   'stall_alpha',         't/c',        'Stall angle (°)'),
        ('max_camber', 'max_endurance_param', 'Max camber', 'Endurance CL^1.5/CD'),
    ]
    fig, axes = plt.subplots(2, 2, figsize=(14, 12))
    for ax, (gx, py, xlabel, ylabel) in zip(axes.flatten(), geo_perf_pairs):
        if gx not in summary_df.columns or py not in summary_df.columns:
            ax.set_visible(False); continue
        for cat in summary_df['category'].unique():
            sub = summary_df[summary_df['category'] == cat]
            ax.scatter(sub[gx], sub[py], alpha=0.3, s=10, label=cat)
        ax.set_xlabel(xlabel); ax.set_ylabel(ylabel)
        ax.legend(fontsize=7, markerscale=3)
    plt.suptitle('Geometry vs Performance', fontsize=11)
    plt.tight_layout()
    plt.savefig(output_dir / 'geometry_vs_performance.png', dpi=300); plt.close()

    # 9. Stall method pie
    if 'stall_method' in summary_df.columns:
        fig, ax = plt.subplots(figsize=(8, 6))
        counts = summary_df['stall_method'].value_counts()
        ax.pie(counts.values, labels=counts.index, autopct='%1.1f%%')
        ax.set_title('Stall Detection Method Distribution')
        plt.tight_layout()
        plt.savefig(output_dir / 'stall_method_distribution.png', dpi=300); plt.close()

    # 10. Drag correction impact — fixed (per-point scatter, not mean)
    if 'CD_raw' in detailed_df.columns and 'CD' in detailed_df.columns:
        fig, ax = plt.subplots(figsize=(10, 6))
        # sample to avoid plotting millions of points
        sample_size = min(20_000, len(detailed_df))
        sample = detailed_df.sample(n=sample_size, random_state=0)
        raw_ld = sample['CL'] / sample['CD_raw'].clip(lower=1e-7)
        corr_ld = sample['LD_ratio']
        mask = (raw_ld.between(-50, 150)) & corr_ld.notna()
        ax.scatter(raw_ld[mask], corr_ld[mask], s=1, alpha=0.1)
        lim = [-50, 150]
        ax.plot(lim, lim, 'r--', alpha=0.5, label='y = x (no correction)')
        ax.set_xlim(lim); ax.set_ylim(lim)
        ax.set_xlabel('L/D (uncorrected)'); ax.set_ylabel('L/D (drag-corrected)')
        ax.set_title(f'Drag Correction Impact (n={mask.sum():,} sampled points)')
        ax.legend()
        plt.tight_layout()
        plt.savefig(output_dir / 'drag_correction_impact.png', dpi=300); plt.close()

    print(f"✓ Visualisations saved to {output_dir}/")


