def load_dat_file(filepath: str) -> tuple[np.ndarray, dict]:
    """Load a .dat airfoil file and extract embedded metadata."""
    meta = {}
    coord_lines = []

    with open(filepath, 'r', encoding='utf-8', errors='replace') as f:
        for line in f:
            stripped = line.strip()
            if stripped.startswith('#'):
                m = re.match(r'#\s*([^:]+):\s*(.+)', stripped)
                if m:
                    meta[m.group(1).strip()] = m.group(2).strip()
                continue
            if not stripped:
                continue
            parts = stripped.split()
            if len(parts) == 2:
                try:
                    coord_lines.append((float(parts[0]), float(parts[1])))
                except ValueError:
                    continue

    if len(coord_lines) < 10:
        raise ValueError(f"Too few coordinate points ({len(coord_lines)}) in {filepath}")

    coords = normalise_airfoil_coordinates(np.array(coord_lines))

    # Parse estimated Re from header
    for key in ('Est. Reynolds', 'Estimated Reynolds Number', 'estimated_reynolds'):
        if key in meta:
            try:
                re_str = meta[key].replace(',', '').replace('e+0', 'e+').replace('e-0', 'e-')
                meta['_estimated_re'] = float(re_str.split()[0])
                meta['_re_method'] = 'header'
                break
            except (ValueError, AttributeError):
                pass

    # Allometric estimation if header missing
    if '_estimated_re' not in meta:
        body_mass_kg = None
        wing_length_mm = 0.0
        wing_loading_proxy = 0.0

        for key in ('Body Mass', 'Body.Mass', 'body_mass_g'):
            if key in meta:
                try:
                    mass_g = float(meta[key].replace('g', '').strip())
                    body_mass_kg = mass_g / 1000.0
                    break
                except (ValueError, AttributeError):
                    pass

        for key in ('Wing Length', 'Wing.Length'):
            if key in meta:
                try:
                    wing_length_mm = float(meta[key].replace('mm', '').strip())
                    break
                except (ValueError, AttributeError):
                    pass

        for key in ('Wing Loading Proxy', 'Wing.Loading.Proxy'):
            if key in meta:
                try:
                    wing_loading_proxy = float(meta[key])
                    break
                except (ValueError, AttributeError):
                    pass

        re_est, method = estimate_reynolds_allometric(
            body_mass_kg, wing_length_mm, wing_loading_proxy)
        meta['_estimated_re'] = re_est
        meta['_re_method'] = method

    filename = Path(filepath).stem
    if 'Species' not in meta:
        parts = filename.split('_')
        if len(parts) >= 3:
            meta['Species'] = '_'.join(parts[2:-1])

    category = Path(filepath).parent.name
    if category in ('diving', 'generalist', 'hovering',
                    'maneuvering', 'soaring', 'cruising'):
        meta['Flight Category'] = category

    meta.update(extract_geometry_descriptors(coords))
    return coords, meta


# ---------------------------------------------------------------------------
# §2  STALL DETECTION — earliest-trigger semantics (fix B)
# ---------------------------------------------------------------------------

def detect_stall(alphas: list[float], cls: list[float]) -> tuple[float, float, str, bool]:
    """
    Detect CLmax and stall angle using earliest-trigger across three methods.

    Methods
    -------
    A. Slope degradation: stall when dCL/dα drops below 40% of the linear
       (α∈[0,6]°) slope.
    B. Curvature: d²CL/dα² < −0.003 /deg².
    C. Peak-drop: first α after CLmax where CL < 0.95·CLmax.

    The *earliest* α among the three triggered methods wins. Ties are
    broken peak_drop > curvature > slope (most physically direct first).

    Returns
    -------
    cl_max       : float
    stall_alpha  : float
    method       : str   which method produced the winning angle
    plausible    : bool  True if stall falls inside STALL_ALPHA_WINDOW
    """
    if len(cls) < 4:
        return (max(cls) if cls else 0.0), (alphas[-1] if alphas else 0.0), 'insufficient_data', False

    a = np.array(alphas, dtype=float)
    cl = np.array(cls, dtype=float)

    i_peak = int(np.argmax(cl))
    cl_max = float(cl[i_peak])

    # ── Method A: slope degradation (40% threshold, docstring-correct) ──
    dcl_da = np.gradient(cl, a)
    linear_mask = (a >= 0) & (a <= 6)
    if np.sum(linear_mask) >= 2:
        slope_linear = float(np.mean(dcl_da[linear_mask]))
    else:
        slope_linear = float(np.mean(dcl_da[:min(4, len(dcl_da))]))

    slope_threshold = 0.40 * slope_linear

    stall_a_slope = None
    # search from the start of the linear region onward (not only after peak)
    for i in range(len(a)):
        if a[i] > 4.0 and dcl_da[i] < slope_threshold:
            stall_a_slope = float(a[i])
            break

    # ── Method B: curvature ────────────────────────────────────────────
    d2cl_da2 = np.gradient(dcl_da, a)
    stall_a_curv = None
    for i in range(len(a)):
        if a[i] > 4.0 and d2cl_da2[i] < -0.003:
            stall_a_curv = float(a[i])
            break

    # ── Method C: peak-drop ───────────────────────────────────────────
    stall_a_peak = None
    threshold_95 = cl_max * 0.95
    for i in range(i_peak + 1, len(cl)):
        if cl[i] < threshold_95:
            stall_a_peak = float(a[i])
            break

    # ── Earliest-trigger selection (fix A) ────────────────────────────
    candidates = []
    if stall_a_peak is not None:
        candidates.append((stall_a_peak, 'peak_drop', 0))   # tie-break rank
    if stall_a_curv is not None:
        candidates.append((stall_a_curv, 'curvature', 1))
    if stall_a_slope is not None:
        candidates.append((stall_a_slope, 'slope_degradation', 2))

    if candidates:
        # sort by (alpha, tie_rank) → earliest α wins; tie → peak_drop first
        candidates.sort(key=lambda t: (t[0], t[2]))
        stall_alpha = candidates[0][0]
        method = candidates[0][1]
    else:
        stall_alpha = float(a[i_peak])
        method = 'fallback_peak'

    # ── Plausibility flag (fix B — no hard clip) ──────────────────────
    lo, hi = STALL_ALPHA_WINDOW
    plausible = (lo <= stall_alpha <= hi)

    return cl_max, stall_alpha, method, plausible


# ---------------------------------------------------------------------------
# §6  ADDITIONAL PERFORMANCE METRICS
# ---------------------------------------------------------------------------

def compute_advanced_metrics(df: pd.DataFrame) -> dict:
    """Endurance, pitch stability, drag bucket width."""
    metrics = {}

    cl_pos = df[df['CL'] > 0].copy()
    if not cl_pos.empty:
        cl_pos['endurance'] = cl_pos['CL'] ** 1.5 / cl_pos['CD']
        metrics['max_endurance_param'] = safe_float(cl_pos['endurance'].max())
        best_end = cl_pos.loc[cl_pos['endurance'].idxmax()]
        metrics['endurance_alpha'] = safe_float(best_end['alpha'])
        metrics['endurance_Re'] = safe_float(best_end['Re'])
    else:
        metrics.update({'max_endurance_param': 0.0, 'endurance_alpha': 0.0, 'endurance_Re': 0.0})

    cm_slopes = []
    for _, grp in df.groupby('Re'):
        grp_s = grp.sort_values('alpha')
        if len(grp_s) >= 4:
            cl_arr = grp_s['CL'].values
            cm_arr = grp_s['CM'].values
            mask = grp_s['alpha'].between(0, 8)
            if mask.sum() >= 3:
                slope, *_ = scipy_stats.linregress(cl_arr[mask.values], cm_arr[mask.values])
                cm_slopes.append(slope)
    metrics['dCM_dCL'] = float(np.median(cm_slopes)) if cm_slopes else 0.0
    metrics['is_statically_stable'] = metrics['dCM_dCL'] < 0

    bucket_widths = []
    for _, grp in df.groupby('Re'):
        grp_s = grp.sort_values('alpha')
        cd_min_local = grp_s['CD'].min()
        in_bucket = grp_s['CD'] < 1.1 * cd_min_local
        if in_bucket.any():
            a_in = grp_s.loc[in_bucket, 'alpha']
            bucket_widths.append(float(a_in.max() - a_in.min()))
    metrics['drag_bucket_width'] = float(np.median(bucket_widths)) if bucket_widths else 0.0

    return metrics


# ---------------------------------------------------------------------------
# CORE SIMULATION
# ---------------------------------------------------------------------------

def run_simulation_for_file(
    dat_file: str,
    reynolds: list[float] = REYNOLDS_NUMBERS,
    alphas:   list[float] = ALPHAS,
    model_size: str = MODEL_SIZE,
) -> tuple[list[dict], dict]:
    """Run the full alpha × Re test matrix for a single .dat file."""
    coords, file_meta = load_dat_file(dat_file)
    bird_name = file_meta.get('Species', Path(dat_file).stem)
    category = file_meta.get('Flight Category', Path(dat_file).parent.name)
    results = []

    for re_val in reynolds:
        k_cd = get_drag_correction(re_val)

        for alpha in alphas:
            try:
                aero = nf.get_aero_from_coordinates(
                    coordinates=coords, alpha=alpha, Re=re_val,
                    model_size=model_size,
                )

                cl = safe_float(aero.get('CL', 0.0))
                cd_raw = safe_float(aero.get('CD', 1e-6))
                cm = safe_float(aero.get('CM', 0.0))
                confidence = safe_float(aero.get('analysis_confidence', 0.0))
                top_xtr = safe_float(aero.get('Top_Xtr', 1.0))
                bot_xtr = safe_float(aero.get('Bot_Xtr', 1.0))

                cd_corrected = max(abs(cd_raw) * k_cd, 1e-7)

                plausible = True
                if cd_corrected < CD_MIN_PLAUSIBLE:
                    cd_corrected = CD_MIN_PLAUSIBLE
                    plausible = False
                if abs(cl) > CL_MAX_PLAUSIBLE:
                    plausible = False

                ld_raw = cl / cd_corrected

                if ld_raw > LD_RAW_FILTER_MAX:
                    ld_raw = np.nan
                    plausible = False

                ld_report = (min(ld_raw, LD_MAX_PLAUSIBLE)
                             if not np.isnan(ld_raw) else np.nan)

                results.append({
                    'bird_name':           bird_name,
                    'category':            category,
                    'file_path':           dat_file,
                    'alpha':               float(alpha),
                    'Re':                  float(re_val),
                    'CL':                  cl,
                    'CD_raw':              abs(cd_raw),
                    'CD':                  cd_corrected,
                    'CD_correction':       k_cd,
                    'CM':                  cm,
                    'LD_ratio':            ld_raw,
                    'LD_report':           ld_report,
                    'analysis_confidence': confidence,
                    'low_confidence':      confidence < CONFIDENCE_THRESHOLD,
                    'plausible':           plausible,
                    'Top_Xtr':             top_xtr,
                    'Bot_Xtr':             bot_xtr,
                })

            except Exception:
                continue

    return results, file_meta


def build_summary(
    bird_name: str,
    category:  str,
    dat_file:  str,
    df:        pd.DataFrame,
    file_meta: dict,
) -> dict | None:
    """
    Compute summary statistics for one bird.

    All reported L/D metrics use LD_report (capped, NaN-filtered) — fix D.
    """
    if df.empty:
        return None

    dfp = df[df['plausible']].copy()
    used_fallback = False
    if dfp.empty:
        dfp = df.copy()
        used_fallback = True   # fix E

    total_points = len(df)
    plausible_frac = (len(dfp) / total_points) if (total_points > 0 and not used_fallback) else 0.0

    # Use LD_report consistently (fix D)
    neg_alpha  = dfp[dfp['alpha'] < 0]
    cruise     = dfp[dfp['alpha'].between(0, 2)]
    design     = dfp[dfp['alpha'] == 4]
    climb      = dfp[dfp['alpha'].between(8, 12)]
    high_alpha = dfp[dfp['alpha'] >= 14]

    ld_series = dfp['LD_report']
    if ld_series.dropna().empty:
        return None  # nothing usable

    idx_best = ld_series.idxmax()
    best_row = dfp.loc[idx_best]

    re_ld = {}
    for re_val, grp in dfp.groupby('Re'):
        re_ld[f'LD_at_Re_{re_val:.0e}'] = safe_float(grp['LD_report'].max())

    estimated_re = file_meta.get('_estimated_re', 1e5)
    re_method = file_meta.get('_re_method', 'unknown')
    re_for_stall = min(REYNOLDS_NUMBERS, key=lambda r: abs(r - estimated_re))
    stall_df = dfp[dfp['Re'] == re_for_stall].sort_values('alpha')

    cl_max, stall_alpha, stall_method, stall_plausible = detect_stall(
        stall_df['alpha'].tolist(),
        stall_df['CL'].tolist(),
    )

    design_re_df = dfp[dfp['Re'] == re_for_stall]
    if not design_re_df.empty and not design_re_df['LD_report'].dropna().empty:
        design_re_ld = safe_float(design_re_df['LD_report'].max())
        design_re_cl = safe_float(design_re_df.loc[design_re_df['LD_report'].idxmax(), 'CL'])
    else:
        design_re_ld = 0.0
        design_re_cl = 0.0

    adv = compute_advanced_metrics(dfp)

    summary = {
        'bird_name': bird_name,
        'category':  category,
        'file_path': dat_file,

        # Global bests — use LD_report (fix D)
        'max_LD': safe_float(ld_series.max()),
        'avg_LD': safe_float(ld_series.mean()),
        'LD_std': safe_float(ld_series.std()),
        'max_CL': safe_float(dfp['CL'].max()),
        'min_CD': safe_float(dfp['CD'].min()),

        # Regime-specific (LD_report)
        'neg_alpha_LD':  safe_float(neg_alpha['LD_report'].mean())  if not neg_alpha.empty  else 0.0,
        'cruise_LD':     safe_float(cruise['LD_report'].mean())     if not cruise.empty     else 0.0,
        'design_LD':     safe_float(design['LD_report'].mean())     if not design.empty     else 0.0,
        'climb_LD':      safe_float(climb['LD_report'].mean())      if not climb.empty      else 0.0,
        'high_alpha_LD': safe_float(high_alpha['LD_report'].mean()) if not high_alpha.empty else 0.0,

        # Stall
        'CL_max':          cl_max,
        'stall_alpha':     stall_alpha,
        'stall_method':    stall_method,
        'stall_plausible': stall_plausible,

        # Reynolds
        'estimated_Re':      estimated_re,
        'Re_method':         re_method,
        'design_point_Re':   re_for_stall,
        'design_point_LD':   design_re_ld,
        'design_point_CL':   design_re_cl,

        # Best op point
        'best_alpha': safe_float(best_row['alpha']),
        'best_Re':    safe_float(best_row['Re']),

        'LD_CoV': safe_float(ld_series.std() / (ld_series.mean() + 1e-6)),

        # Quality
        'avg_confidence':           safe_float(df['analysis_confidence'].mean()),
        'low_conf_fraction':        safe_float(df['low_confidence'].mean()),
        'plausible_fraction':       plausible_frac,
        'used_implausible_fallback': used_fallback,   # fix E
        'conditions_tested':        total_points,

        # Advanced
        **adv,

        # Geometry
        't_over_c':   file_meta.get('t_over_c', 0.0),
        'max_camber': file_meta.get('max_camber', 0.0),
        'camber_loc': file_meta.get('camber_loc', 0.0),

        **re_ld,
    }

    return summary


