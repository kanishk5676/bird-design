def export_champions(
    summary_df: pd.DataFrame,
    category_leaders: dict,
    output_dir: Path,
    top_n: int = TOP_N_OVERALL,
) -> tuple[pd.DataFrame, pd.DataFrame]:
    """
    Export champion birds to dedicated CSVs.

    Produces two files:
      1. champions_by_category.csv  — best bird per category (rich columns,
         plus the narrative reasons as a joined string).
      2. overall_top_birds.csv      — top-N birds globally by max_LD,
         with a rank column and category tag.

    Both files are self-contained (full summary columns included) so they
    can be consumed without needing summary_analysis.csv.
    """
    if summary_df.empty:
        return pd.DataFrame(), pd.DataFrame()

    # ── 1. Champions by category ─────────────────────────────────────
    champion_rows = []
    for category, data in category_leaders.items():
        leader = data['leader'].copy()
        reasons = data.get('performance_reasons', [])
        leader['performance_reasons'] = ' | '.join(reasons)
        leader['category_rank'] = 1
        leader['category_size'] = data['category_stats']['count']
        leader['category_mean_LD'] = data['category_stats']['mean_LD']
        leader['category_std_LD'] = data['category_stats']['std_LD']
        leader['LD_vs_category_mean_pct'] = (
            (safe_float(leader['max_LD']) - data['category_stats']['mean_LD']) /
            (data['category_stats']['mean_LD'] + 1e-9) * 100
        )
        champion_rows.append(leader)

    champions_df = pd.DataFrame(champion_rows)
    # Put the most informative columns first
    priority_cols = ['category', 'bird_name', 'max_LD', 'CL_max', 'stall_alpha',
                     'min_CD', 'cruise_LD', 'climb_LD', 'max_endurance_param',
                     'dCM_dCL', 't_over_c', 'max_camber',
                     'LD_vs_category_mean_pct', 'performance_reasons']
    existing = [c for c in priority_cols if c in champions_df.columns]
    other = [c for c in champions_df.columns if c not in existing]
    champions_df = champions_df[existing + other]

    champions_path = output_dir / "champions_by_category.csv"
    champions_df.to_csv(champions_path, index=False)

    # ── 2. Overall top-N birds across all categories ────────────────
    # Exclude birds with fallback data (they're on garbage)
    usable = summary_df.copy()
    if 'used_implausible_fallback' in usable.columns:
        usable = usable[~usable['used_implausible_fallback']]
    if 'stall_plausible' in usable.columns:
        usable = usable[usable['stall_plausible']]

    top_overall = usable.nlargest(top_n, 'max_LD').reset_index(drop=True).copy()
    top_overall.insert(0, 'overall_rank', top_overall.index + 1)

    # Reorder for readability
    overall_priority = ['overall_rank', 'bird_name', 'category', 'max_LD',
                        'CL_max', 'stall_alpha', 'min_CD', 'cruise_LD',
                        'climb_LD', 'max_endurance_param', 'dCM_dCL',
                        't_over_c', 'max_camber', 'best_alpha', 'best_Re']
    existing = [c for c in overall_priority if c in top_overall.columns]
    other = [c for c in top_overall.columns if c not in existing]
    top_overall = top_overall[existing + other]

    overall_path = output_dir / "overall_top_birds.csv"
    top_overall.to_csv(overall_path, index=False)

    print(f"\n✓ Champions by category → {champions_path.name} "
          f"({len(champions_df)} rows)")
    print(f"✓ Overall top-{top_n} birds → {overall_path.name} "
          f"({len(top_overall)} rows, {len(usable)} usable in pool)")

    return champions_df, top_overall


