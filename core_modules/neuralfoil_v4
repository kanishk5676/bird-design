# §7  GEOMETRY–PERFORMANCE CORRELATIONS
# ---------------------------------------------------------------------------

def compute_geometry_correlations(summary_df: pd.DataFrame, output_dir: Path) -> pd.DataFrame:
    """Pearson & Spearman correlations between geometry and performance."""
    geo_cols = [c for c in ['t_over_c', 'max_camber', 'camber_loc'] if c in summary_df.columns]
    perf_cols = [c for c in ['max_LD', 'cruise_LD', 'climb_LD', 'CL_max',
                             'stall_alpha', 'min_CD', 'max_endurance_param',
                             'drag_bucket_width'] if c in summary_df.columns]

    if not geo_cols or not perf_cols:
        print("⚠️  Insufficient columns for correlation analysis.")
        return pd.DataFrame()

    rows = []

    def _correlate(df_sub, group_label):
        for gc in geo_cols:
            for pc in perf_cols:
                valid = df_sub[[gc, pc]].dropna()
                if len(valid) < 10 or valid[gc].nunique() < 5:
                    continue
                r_p, p_p = scipy_stats.pearsonr(valid[gc], valid[pc])
                r_s, p_s = scipy_stats.spearmanr(valid[gc], valid[pc])
                rows.append({'group': group_label, 'geometry': gc, 'performance': pc,
                             'pearson_r': r_p, 'pearson_p': p_p,
                             'spearman_r': r_s, 'spearman_p': p_s, 'n': len(valid)})

    _correlate(summary_df, 'ALL')
    for cat in summary_df['category'].unique():
        _correlate(summary_df[summary_df['category'] == cat], cat)

    corr_df = pd.DataFrame(rows)
    corr_df.to_csv(output_dir / "geometry_performance_correlations.csv", index=False)

    sig = corr_df[(corr_df['spearman_p'] < 0.01) & (corr_df['n'] >= 20)]
    if not sig.empty:
        print("\nSignificant geometry–performance correlations (p < 0.01):")
        for _, row in sig.iterrows():
            print(f"  [{row['group']:>14s}]  {row['geometry']} vs {row['performance']}: "
                  f"r_s = {row['spearman_r']:+.3f}  (n={row['n']})")
    else:
        print("\nNo significant geometry–performance correlations found (p < 0.01).")

    return corr_df


