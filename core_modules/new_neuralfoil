def run_naca_validation(output_dir: Path) -> pd.DataFrame:
    """
    Run NeuralFoil on 3 NACA airfoils and compare against published data.
    Produces a validation table and CL-α comparison plots.

    Returns a DataFrame with pass/fail for each metric.
    """
    output_dir.mkdir(parents=True, exist_ok=True)
    rows = []

    naca_ids = ['0012', '2412', '4412']
    val_re_list = [1e5, 5e5]

    fig_cl, axes_cl = plt.subplots(1, 3, figsize=(16, 5), sharey=True)
    fig_cd, axes_cd = plt.subplots(1, 3, figsize=(16, 5), sharey=True)

    for idx, naca_id in enumerate(naca_ids):
        coords = generate_naca_4digit(naca_id)
        label = f"NACA_{naca_id}"

        for re_val in val_re_list:
            re_key = f"Re_{re_val:.0e}".replace('+0', '+')
            cls_list, cds_list, alphas_out = [], [], []

            for alpha in ALPHAS:
                try:
                    aero = nf.get_aero_from_coordinates(
                        coordinates=coords, alpha=alpha,
                        Re=re_val, model_size=MODEL_SIZE)
                    cls_list.append(safe_float(aero.get('CL', 0.0)))
                    cds_list.append(max(abs(safe_float(aero.get('CD', 1e-6))), 1e-7))
                    alphas_out.append(alpha)
                except Exception:
                    continue

            if len(cls_list) < 4:
                continue

            # Extract metrics
            cl_max_nf, stall_nf = detect_stall(alphas_out, cls_list)
            cd_min_nf = min(cds_list)

            # Lift-curve slope in linear region
            a_arr = np.array(alphas_out)
            cl_arr = np.array(cls_list)
            lin = (a_arr >= -2) & (a_arr <= 6)
            if np.sum(lin) >= 2:
                slope_nf = float(np.polyfit(a_arr[lin], cl_arr[lin], 1)[0])
            else:
                slope_nf = 0.0

            # Compare with reference
            re_label = f"Re_{int(re_val):.0e}".replace("e+0", "e").replace("e+", "e")
            ref = NACA_REFERENCE_DATA.get(label, {}).get(re_label, {})

            for metric_name, nf_val in [('CLmax', cl_max_nf),
                                         ('stall_alpha', stall_nf),
                                         ('CL_slope', slope_nf),
                                         ('CD_min', cd_min_nf)]:
                ref_val, ref_tol = ref.get(metric_name, (None, None))
                if ref_val is not None:
                    error = nf_val - ref_val
                    within = abs(error) <= ref_tol
                    rows.append({
                        'Airfoil': label,
                        'Re': re_val,
                        'Metric': metric_name,
                        'NeuralFoil': round(nf_val, 4),
                        'Reference': ref_val,
                        'Tolerance': ref_tol,
                        'Error': round(error, 4),
                        'Pass': within,
                    })

            # Plot CL-α
            axes_cl[idx].plot(alphas_out, cls_list,
                              marker='o', markersize=3,
                              label=f"NF Re={re_val:.0e}")
            # Plot CD-α
            axes_cd[idx].plot(alphas_out, cds_list,
                              marker='o', markersize=3,
                              label=f"NF Re={re_val:.0e}")

        axes_cl[idx].set_title(f"NACA {naca_id}")
        axes_cl[idx].set_xlabel("α (°)")
        axes_cl[idx].legend(fontsize=7)
        axes_cl[idx].grid(True, alpha=0.3)
        axes_cd[idx].set_title(f"NACA {naca_id}")
        axes_cd[idx].set_xlabel("α (°)")
        axes_cd[idx].legend(fontsize=7)
        axes_cd[idx].grid(True, alpha=0.3)

    axes_cl[0].set_ylabel("CL")
    axes_cd[0].set_ylabel("CD")
    fig_cl.suptitle("NeuralFoil Validation — CL vs α", fontsize=12)
    fig_cd.suptitle("NeuralFoil Validation — CD vs α", fontsize=12)
    fig_cl.tight_layout()
    fig_cd.tight_layout()
    fig_cl.savefig(output_dir / "validation_cl_alpha.png", dpi=300)
    fig_cd.savefig(output_dir / "validation_cd_alpha.png", dpi=300)
    plt.close('all')

    val_df = pd.DataFrame(rows)
    val_df.to_csv(output_dir / "naca_validation.csv", index=False)
    print(f"✓ NACA validation saved ({len(val_df)} checks, "
          f"{val_df['Pass'].sum()} passed)")
    return val_df


# ---------------------------------------------------------------------------
# CORE SIMULATION  (with plausibility filtering)
# ---------------------------------------------------------------------------

def run_simulation_for_file(
    dat_file:   str,
    reynolds:   list[float] = REYNOLDS_NUMBERS,
    alphas:     list[float] = ALPHAS,
    model_size: str         = MODEL_SIZE,
) -> tuple[list[dict], dict]:

    coords, file_meta = load_dat_file(dat_file)
    bird_name = file_meta.get('Species', Path(dat_file).stem)
    category  = file_meta.get('Flight Category', Path(dat_file).parent.name)

    # ── FIX 2b: extract shape metrics ──
    try:
        shape = extract_shape_metrics(coords)
    except Exception:
        shape = {}

    file_meta['_shape'] = shape
    results = []

    for re_val in reynolds:
        for alpha in alphas:
            try:
                aero = nf.get_aero_from_coordinates(
                    coordinates=coords, alpha=alpha,
                    Re=re_val, model_size=model_size)

                cl         = safe_float(aero.get('CL', 0.0))
                cd         = safe_float(aero.get('CD', 1e-6))
                cm         = safe_float(aero.get('CM', 0.0))
                confidence = safe_float(aero.get('analysis_confidence', 0.0))
                top_xtr    = safe_float(aero.get('Top_Xtr', 1.0))
                bot_xtr    = safe_float(aero.get('Bot_Xtr', 1.0))

                cd = max(abs(cd), 1e-7)
                ld = cl / cd

                # ── FIX 1: Plausibility flags ──
                plausible = True
                if abs(ld) > MAX_PLAUSIBLE_LD:
                    plausible = False
                if cd < MIN_PLAUSIBLE_CD:
                    plausible = False
                if abs(cl) > MAX_PLAUSIBLE_CL:
                    plausible = False

                results.append({
                    'bird_name':           bird_name,
                    'category':            category,
                    'file_path':           dat_file,
                    'alpha':               float(alpha),
                    'Re':                  float(re_val),
                    'CL':                  cl,
                    'CD':                  cd,
                    'CM':                  cm,
                    'LD_ratio':            ld,
                    'analysis_confidence': confidence,
                    'low_confidence':      confidence < CONFIDENCE_THRESHOLD,
                    'plausible':           plausible,
                    'Top_Xtr':             top_xtr,
                    'Bot_Xtr':             bot_xtr,
                })
            except Exception:
                continue

    return results, file_meta


# ---------------------------------------------------------------------------
# SUMMARY BUILDER  (with filtered and raw metrics)
# ---------------------------------------------------------------------------

def build_summary(
    bird_name: str, category: str, dat_file: str,
    df: pd.DataFrame, file_meta: dict,
) -> dict | None:

    if df.empty:
        return None

    # ── FIX 1b: Separate raw and filtered DataFrames ──
    df_raw = df
    df_filt = df[df['plausible'] == True].copy()  # noqa: E712
    if df_filt.empty:
        df_filt = df_raw  # fall back if everything was flagged

    # Use filtered data for headline metrics
    neg_alpha  = df_filt[df_filt['alpha'] < 0]
    cruise     = df_filt[df_filt['alpha'].between(0, 2)]
    climb      = df_filt[df_filt['alpha'].between(8, 12)]
    high_alpha = df_filt[df_filt['alpha'] >= 14]

    idx_best = df_filt['LD_ratio'].idxmax()
    best_row = df_filt.loc[idx_best]

    # Per-Re best L/D (filtered)
    re_ld = {}
    for re_val, grp in df_filt.groupby('Re'):
        re_ld[f'LD_at_Re_{re_val:.0e}'] = safe_float(grp['LD_ratio'].max())

    # Stall detection at estimated Re
    estimated_re = file_meta.get('_estimated_re', 1e5)
    re_for_stall = min(REYNOLDS_NUMBERS, key=lambda r: abs(r - estimated_re))
    stall_df = df_raw[df_raw['Re'] == re_for_stall].sort_values('alpha')
    cl_max, stall_alpha = detect_stall(
        stall_df['alpha'].tolist(), stall_df['CL'].tolist())

    # Design-point
    design_re_df = df_filt[df_filt['Re'] == re_for_stall]
    design_re_ld = (safe_float(design_re_df['LD_ratio'].max())
                    if not design_re_df.empty else 0.0)

    # ── FIX 4: Confidence-weighted L/D ──
    weights = df_filt['analysis_confidence'].clip(lower=0.1)
    weighted_ld = float(np.average(df_filt['LD_ratio'], weights=weights))

    # ── FIX 2c: Shape metrics ──
    shape = file_meta.get('_shape', {})

    # Fraction of conditions that were plausible
    plausible_frac = float(df_raw['plausible'].mean())

    summary = {
        'bird_name':            bird_name,
        'category':             category,
        'file_path':            dat_file,

        # ── Headline metrics (FILTERED) ──
        'max_LD':               safe_float(df_filt['LD_ratio'].max()),
        'avg_LD':               safe_float(df_filt['LD_ratio'].mean()),
        'weighted_avg_LD':      weighted_ld,
        'LD_std':               safe_float(df_filt['LD_ratio'].std()),
        'max_CL':               safe_float(df_filt['CL'].max()),
        'min_CD':               safe_float(df_filt['CD'].min()),

        # ── Raw (unfiltered) for transparency ──
        'raw_max_LD':           safe_float(df_raw['LD_ratio'].max()),
        'raw_avg_LD':           safe_float(df_raw['LD_ratio'].mean()),

        # Regime L/D
        'neg_alpha_LD':   safe_float(neg_alpha['LD_ratio'].mean())  if not neg_alpha.empty  else 0.0,
        'cruise_LD':      safe_float(cruise['LD_ratio'].mean())     if not cruise.empty     else 0.0,
        'climb_LD':       safe_float(climb['LD_ratio'].mean())      if not climb.empty      else 0.0,
        'high_alpha_LD':  safe_float(high_alpha['LD_ratio'].mean()) if not high_alpha.empty else 0.0,

        # Stall
        'CL_max':               cl_max,
        'stall_alpha':          stall_alpha,
        'estimated_Re':         estimated_re,
        'design_point_Re':      re_for_stall,
        'design_point_LD':      design_re_ld,

        'best_alpha':           safe_float(best_row['alpha']),
        'best_Re':              safe_float(best_row['Re']),

        'LD_CoV':               safe_float(
                                    df_filt['LD_ratio'].std()
                                    / (df_filt['LD_ratio'].mean() + 1e-6)),
        'avg_confidence':       safe_float(df_raw['analysis_confidence'].mean()),
        'low_conf_fraction':    safe_float(df_raw['low_confidence'].mean()),
        'plausible_fraction':   plausible_frac,
        'conditions_tested':    len(df_raw),
        'conditions_plausible': int(df_raw['plausible'].sum()),

        # ── Shape metrics ──
        'max_thickness':        shape.get('max_thickness', np.nan),
        'max_thickness_loc':    shape.get('max_thickness_loc', np.nan),
        'max_camber':           shape.get('max_camber', np.nan),
        'max_camber_loc':       shape.get('max_camber_loc', np.nan),
        'le_radius':            shape.get('le_radius_approx', np.nan),
        'te_angle_deg':         shape.get('te_angle_deg', np.nan),

        **re_ld,
    }
    return summary


