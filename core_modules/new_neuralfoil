def safe_float(value) -> float:
    """Convert any value (scalar, list, ndarray) to a Python float."""
    if value is None:
        return 0.0
    if isinstance(value, np.ndarray):
        if value.ndim == 0:
            return float(value.item())
        else:
            flat = value.flatten()
            return float(flat[0]) if len(flat) > 0 else 0.0
    if isinstance(value, (list, tuple)):
        return float(value[0]) if len(value) > 0 else 0.0
    if hasattr(value, '__iter__') and not isinstance(value, (str, bytes)):
        try:
            arr = np.asarray(value).flatten()
            return float(arr[0]) if len(arr) > 0 else 0.0
        except (TypeError, ValueError, IndexError):
            pass
    try:
        return float(value)
    except (TypeError, ValueError, AttributeError):
        return 0.0


def normalise_airfoil_coordinates(coords: np.ndarray) -> np.ndarray:
    x = coords[:, 0]
    chord = x.max() - x.min()
    if chord < 1e-9:
        raise ValueError("Degenerate airfoil: chord length is effectively zero.")
    x_le = x.min()
    normalised = coords.copy()
    normalised[:, 0] = (coords[:, 0] - x_le) / chord
    normalised[:, 1] = coords[:, 1] / chord
    return normalised


def estimate_reynolds_from_morphology(wing_length_mm: float,
                                       wing_loading_proxy: float) -> float:
    velocity = max(5.0, min(30.0,
                            8.0 + 200.0 * wing_loading_proxy
                            + 0.05 * wing_length_mm))
    chord_m = wing_length_mm / 1000.0 * 0.15
    re = 67679.0 * velocity * chord_m
    return np.clip(re, 1e4, 2e6)


def load_dat_file(filepath: str) -> tuple[np.ndarray, dict]:
    meta = {}
    coord_lines = []
    with open(filepath, 'r', encoding='utf-8', errors='replace') as f:
        for line in f:
            stripped = line.strip()
            if stripped.startswith('#'):
                m = re.match(r'#\s*([^:]+):\s*(.+)', stripped)
                if m:
                    meta[m.group(1).strip()] = m.group(2).strip()
                continue
            if not stripped:
                continue
            parts = stripped.split()
            if len(parts) == 2:
                try:
                    coord_lines.append((float(parts[0]), float(parts[1])))
                except ValueError:
                    continue
    if len(coord_lines) < 10:
        raise ValueError(
            f"Too few coordinate points ({len(coord_lines)}) in {filepath}")
    coords = normalise_airfoil_coordinates(np.array(coord_lines))

    for key in ('Est. Reynolds', 'Estimated Reynolds Number',
                'estimated_reynolds'):
        if key in meta:
            try:
                re_val = (meta[key].replace(',', '')
                          .replace('e+0', 'e+').replace('e-0', 'e-'))
                meta['_estimated_re'] = float(re_val.split()[0])
                break
            except (ValueError, AttributeError):
                pass

    if '_estimated_re' not in meta:
        wing_length = 0.0
        wing_loading = 0.0
        for key in ('Wing Length', 'Wing.Length'):
            if key in meta:
                try:
                    wing_length = float(meta[key].replace('mm', '').strip())
                    break
                except (ValueError, AttributeError):
                    pass
        for key in ('Wing Loading Proxy', 'Wing.Loading.Proxy'):
            if key in meta:
                try:
                    wing_loading = float(meta[key])
                    break
                except (ValueError, AttributeError):
                    pass
        if wing_length > 0:
            meta['_estimated_re'] = estimate_reynolds_from_morphology(
                wing_length, wing_loading)

    filename = Path(filepath).stem
    if 'Species' not in meta:
        parts = filename.split('_')
        if len(parts) >= 3:
            meta['Species'] = '_'.join(parts[2:-1])

    category = Path(filepath).parent.name
    if category in ['diving', 'generalist', 'hovering',
                     'maneuvering', 'soaring', 'cruising']:
        meta['Flight Category'] = category

    return coords, meta


# ── FIX 2: Shape metrics ────────────────────────────────────────────────
def extract_shape_metrics(coords: np.ndarray) -> dict:
    """
    Compute geometric descriptors that link airfoil *shape* to
    aerodynamic *performance*, enabling mechanistic (not just numerical)
    category comparisons.

    Returns
    -------
    dict with keys:
        max_thickness       : t/c ratio
        max_thickness_loc   : x/c location of max thickness
        max_camber          : maximum camber / chord
        max_camber_loc      : x/c location of max camber
        le_radius_approx    : approximate leading-edge radius (1/curvature)
        te_angle_deg        : trailing-edge included angle (degrees)
        area                : enclosed cross-section area / c²
    """
    x = coords[:, 0]
    y = coords[:, 1]

    # Split into upper and lower surfaces at the leading edge
    i_le = int(np.argmin(x))
    x_upper = np.flip(x[:i_le + 1])
    y_upper = np.flip(y[:i_le + 1])
    x_lower = x[i_le:]
    y_lower = y[i_le:]

    # Interpolate both surfaces onto a common x grid
    x_grid = np.linspace(0, 1, 201)
    y_up = np.interp(x_grid, x_upper, y_upper)
    y_lo = np.interp(x_grid, x_lower, y_lower)

    thickness = y_up - y_lo
    camber = (y_up + y_lo) / 2.0

    max_t = float(np.max(thickness))
    max_t_loc = float(x_grid[np.argmax(thickness)])
    max_c = float(np.max(np.abs(camber)))
    max_c_loc = float(x_grid[np.argmax(np.abs(camber))])

    # Leading-edge radius: fit a circle to the first few points
    # Approximate as  r ≈ t²/(4*camber) near LE, or use curvature
    le_pts = min(10, len(x_upper) // 4)
    if le_pts >= 3:
        dx = np.diff(x_upper[:le_pts])
        dy = np.diff(y_upper[:le_pts])
        ds = np.sqrt(dx**2 + dy**2) + 1e-12
        ddx = np.diff(dx)
        ddy = np.diff(dy)
        curvature = np.abs(dx[:-1]*ddy - dy[:-1]*ddx) / (ds[:-1]**3 + 1e-12)
        mean_curv = float(np.mean(curvature[curvature > 0])) if np.any(curvature > 0) else 1e-6
        le_radius = 1.0 / (mean_curv + 1e-9)
    else:
        le_radius = 0.0

    # Trailing-edge included angle
    # Use the last few points of upper and lower surfaces
    n_te = min(5, len(x_upper) // 4, len(x_lower) // 4)
    if n_te >= 2:
        slope_up = np.polyfit(x_upper[-n_te:], y_upper[-n_te:], 1)[0]
        slope_lo = np.polyfit(x_lower[-n_te:], y_lower[-n_te:], 1)[0]
        te_angle = float(np.degrees(np.arctan(slope_up) - np.arctan(slope_lo)))
    else:
        te_angle = 0.0

    # Cross-section area (dimensionless, /c²)
    area = float(np.trapezoid(thickness, x_grid))

    return {
        'max_thickness':     max_t,
        'max_thickness_loc': max_t_loc,
        'max_camber':        max_c,
        'max_camber_loc':    max_c_loc,
        'le_radius_approx':  le_radius,
        'te_angle_deg':      te_angle,
        'area':              area,
    }


# ── FIX 3: Improved stall detection ─────────────────────────────────────
def detect_stall(alphas: list[float], cls: list[float]) -> tuple[float, float]:
    """
    Detect CLmax and stall angle using a **slope-break** method that
    does not rely on NeuralFoil predicting an actual CL drop.

    Algorithm
    ---------
    1. Compute dCL/dα by central differences.
    2. In the linear region (α ≤ 6°) compute the baseline lift-curve
       slope  a₀ = mean(dCL/dα).
    3. Walk from α = 6° upward.  The first α where dCL/dα falls below
       STALL_CL_DROP_FRAC × a₀  (i.e. 2 % of the linear slope) is the
       stall angle.  If no such point exists within the sweep, report
       the sweep ceiling as a *lower bound* on stall angle and flag it.
    4. CLmax = CL at the identified stall angle.

    This avoids the v1 bug where stall was always at the sweep edge
    because NeuralFoil's surrogate doesn't produce a CL reversal.
    """
    if len(cls) < 4:
        return 0.0, 0.0

    a = np.array(alphas, dtype=float)
    cl = np.array(cls, dtype=float)

    # Sort by alpha
    order = np.argsort(a)
    a = a[order]
    cl = cl[order]

    # Central-difference dCL/dα  (deg⁻¹)
    dcl_da = np.gradient(cl, a)

    # Baseline slope from linear region (α in [-2°, 6°])
    linear_mask = (a >= -2) & (a <= 6)
    if np.sum(linear_mask) < 2:
        linear_mask = np.ones_like(a, dtype=bool)
    a0 = float(np.mean(dcl_da[linear_mask]))

    if a0 < 1e-6:
        # Non-lifting or bad data
        return float(np.max(cl)), float(a[np.argmax(cl)])

    # Walk from first α > 6° looking for slope collapse
    stall_alpha = float(a[-1])  # default: sweep ceiling
    stall_detected = False
    for i in range(len(a)):
        if a[i] <= 6:
            continue
        if dcl_da[i] < STALL_CL_DROP_FRAC * a0:
            stall_alpha = float(a[i])
            stall_detected = True
            break

    # If slope never collapsed, also check for absolute CL peak
    i_peak = int(np.argmax(cl))
    if not stall_detected and i_peak < len(cl) - 1:
        # CL started decreasing before sweep end
        if cl[i_peak] > cl[-1] * 1.02:
            stall_alpha = float(a[i_peak])

    cl_max = float(cl[a <= stall_alpha].max()) if np.any(a <= stall_alpha) else float(np.max(cl))

    return cl_max, stall_alpha


