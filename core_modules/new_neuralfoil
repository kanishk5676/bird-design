# ── FIX 1: Plausibility bounds ──────────────────────────────────────────
# Empirical upper bounds for bird-scale airfoils (Re 1e4–1e6).
# Values outside these are flagged and excluded from "headline" metrics.
MAX_PLAUSIBLE_LD   = 120.0   # Glider-class ceiling; generous for bio-airfoils
MIN_PLAUSIBLE_CD   = 0.003   # Below this NeuralFoil likely under-predicts drag
