def generate_naca_4digit(naca_str: str, n_pts: int = 161) -> np.ndarray:
    """
    Generate NACA 4-digit airfoil coordinates.
    naca_str: e.g. '4412', '2412', '0012'
    """
    m = int(naca_str[0]) / 100.0    # max camber
    p = int(naca_str[1]) / 10.0     # location of max camber
    t = int(naca_str[2:]) / 100.0   # max thickness

    beta = np.linspace(0, np.pi, n_pts)
    x = 0.5 * (1 - np.cos(beta))   # cosine spacing

    # Thickness distribution
    yt = 5 * t * (0.2969 * np.sqrt(x)
                  - 0.1260 * x
                  - 0.3516 * x**2
                  + 0.2843 * x**3
                  - 0.1015 * x**4)

    # Camber line
    if m == 0 or p == 0:
        yc = np.zeros_like(x)
        dyc_dx = np.zeros_like(x)
    else:
        yc = np.where(x < p,
                      m / p**2 * (2 * p * x - x**2),
                      m / (1 - p)**2 * ((1 - 2*p) + 2*p*x - x**2))
        dyc_dx = np.where(x < p,
                          2 * m / p**2 * (p - x),
                          2 * m / (1 - p)**2 * (p - x))

    theta = np.arctan(dyc_dx)
    xu = x  - yt * np.sin(theta)
    yu = yc + yt * np.cos(theta)
    xl = x  + yt * np.sin(theta)
    yl = yc - yt * np.cos(theta)

    # Assemble in Selig order (upper TE→LE, lower LE→TE)
    coords = np.vstack([
        np.column_stack([np.flip(xu), np.flip(yu)]),
        np.column_stack([xl[1:], yl[1:]]),
    ])
    return coords


