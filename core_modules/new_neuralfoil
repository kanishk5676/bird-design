def analyze_category_leaders(summary_df, detailed_df, output_dir):
    leaders = {}
    for category in summary_df['category'].unique():
        cat = summary_df[summary_df['category'] == category]
        if cat.empty:
            continue

        top_overall    = cat.nlargest(3, 'max_LD')
        top_cruise     = cat.nlargest(3, 'cruise_LD')
        top_stall      = cat.nlargest(3, 'CL_max')
        top_consistent = cat.nsmallest(3, 'LD_CoV')

        leader = cat.loc[cat['max_LD'].idxmax()]
        leader_name = leader['bird_name']
        leader_det = detailed_df[detailed_df['bird_name'] == leader_name]
        reasons = build_performance_reasons(leader, leader_det, cat)

        leaders[category] = {
            'leader':              leader.to_dict(),
            'top_3_overall':       top_overall[['bird_name', 'max_LD', 'avg_LD']].to_dict('records'),
            'top_3_cruise':        top_cruise[['bird_name', 'cruise_LD']].to_dict('records'),
            'top_3_cl_max':        top_stall[['bird_name', 'CL_max', 'stall_alpha']].to_dict('records'),
            'top_3_consistent':    top_consistent[['bird_name', 'LD_CoV']].to_dict('records'),
            'performance_reasons': reasons,
            'category_stats': {
                'count':              int(len(cat)),
                'mean_LD':            float(cat['max_LD'].mean()),
                'std_LD':             float(cat['max_LD'].std()),
                'mean_CL':            float(cat['CL_max'].mean()),
                'mean_stall':         float(cat['stall_alpha'].mean()),
                'std_stall':          float(cat['stall_alpha'].std()),
                'mean_thickness':     float(cat['max_thickness'].mean()),
                'mean_camber':        float(cat['max_camber'].mean()),
                'plausible_fraction': float(cat['plausible_fraction'].mean()),
            },
        }

    with open(output_dir / "category_leaders.pkl", 'wb') as f:
        pickle.dump(leaders, f)
    return leaders


def build_performance_reasons(leader, leader_det, category_df):
    reasons = []
    cat_mean = safe_float(category_df['max_LD'].mean())
    ldr_ld = safe_float(leader['max_LD'])

    if ldr_ld > cat_mean * 1.02:
        pct = (ldr_ld - cat_mean) / (cat_mean + 1e-6) * 100
        reasons.append(
            f"Filtered peak L/D of {ldr_ld:.1f} is {pct:.0f}% above "
            f"category mean ({cat_mean:.1f}).")

    if safe_float(leader['min_CD']) < safe_float(
            category_df['min_CD'].quantile(0.25)):
        reasons.append(
            f"Min CD = {safe_float(leader['min_CD']):.5f} (bottom quartile), "
            f"suggesting extended laminar run.")

    # ── FIX 2d: Shape-based reasons ──
    t = safe_float(leader.get('max_thickness', 0))
    c = safe_float(leader.get('max_camber', 0))
    if t > 0 and c > 0:
        reasons.append(
            f"Geometry: t/c = {t:.1%}, max camber = {c:.1%} at "
            f"x/c = {safe_float(leader.get('max_camber_loc', 0)):.0%} — "
            f"links shape to observed performance.")

    stall_a = safe_float(leader['stall_alpha'])
    cat_stall_med = safe_float(category_df['stall_alpha'].median())
    if stall_a < cat_stall_med:
        reasons.append(
            f"Stall at {stall_a:.1f}° (below category median {cat_stall_med:.1f}°) "
            f"— early onset may limit usable envelope.")
    elif stall_a > safe_float(category_df['stall_alpha'].quantile(0.75)):
        reasons.append(
            f"Stall delayed to {stall_a:.1f}° (top quartile), "
            f"providing a wide usable α range.")

    plaus = safe_float(leader.get('plausible_fraction', 1.0))
    if plaus < 0.9:
        reasons.append(
            f"Only {plaus:.0%} of test conditions were plausible — "
            f"headline L/D may still be optimistic.")

    if not reasons:
        reasons.append(
            f"Best filtered L/D in category ({ldr_ld:.1f}), balanced "
            f"across flight regimes.")
    return reasons


